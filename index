// ── LIGHTBOX ──
var LB_DATA=null;
function openLightboxDirect(dataUrl,name,type){
  if(!dataUrl){showToast('Archivo no disponible');return;}
  LB_DATA={dataUrl:dataUrl,name:name||'Archivo',type:type};
  document.getElementById('lb-title').textContent=name||'Documento';
  var img=document.getElementById('lb-img'),
      pdf=document.getElementById('lb-pdf'),
      no=document.getElementById('lb-nopreview'),
      noName=document.getElementById('lb-nopreview-name'),
      extBtn=document.getElementById('lb-ext-btn');
  img.style.display='none';pdf.style.display='none';no.style.display='none';
  if(extBtn)extBtn.style.display='none';
  if(type==='img'){img.src=dataUrl;img.style.display='block';}
  else if(type==='pdf'){
    try{
      var b64=dataUrl.split(',')[1],bin=atob(b64),buf=new Uint8Array(bin.length);
      for(var i=0;i<bin.length;i++)buf[i]=bin.charCodeAt(i);
      var blob=new Blob([buf],{type:'application/pdf'}),blobUrl=URL.createObjectURL(blob);
      LB_DATA._blobUrl=blobUrl;
      if(isIOS){
        no.style.display='flex';
        if(noName)noName.textContent=name||'';
        if(extBtn){extBtn.style.display='inline-flex';extBtn.textContent='Abrir PDF ↗';}
      } else {
        pdf.src=blobUrl;pdf.style.display='block';
        pdf.onerror=function(){
          pdf.style.display='none';no.style.display='flex';
          if(noName)noName.textContent=name||'';
          if(extBtn)extBtn.style.display='inline-flex';
        };
      }
    } catch(e){
      no.style.display='flex';
      if(noName)noName.textContent=name||'';
      if(extBtn)extBtn.style.display='inline-flex';
    }
  } else {
    no.style.display='flex';
    if(noName)noName.textContent=name||'';
    if(extBtn)extBtn.style.display='inline-flex';
  }
  document.getElementById('lightbox').classList.add('open');
}
function lbOpenExternal(){
  if(!LB_DATA)return;
  if(LB_DATA._blobUrl){window.open(LB_DATA._blobUrl,'_blank');return;}
  try{
    var arr=LB_DATA.dataUrl.split(','),mime=arr[0].match(/:(.*?);/)[1],
        bstr=atob(arr[1]),n=bstr.length,u8=new Uint8Array(n);
    while(n--)u8[n]=bstr.charCodeAt(n);
    var blob=new Blob([u8],{type:mime}),url=URL.createObjectURL(blob);
    window.open(url,'_blank');
    setTimeout(function(){URL.revokeObjectURL(url);},15000);
  } catch(e){window.open(LB_DATA.dataUrl,'_blank');}
}
function closeLB(){
  document.getElementById('lightbox').classList.remove('open');
  var pdf=document.getElementById('lb-pdf');pdf.src='';
  var img=document.getElementById('lb-img');img.src='';
  if(LB_DATA&&LB_DATA._blobUrl){try{URL.revokeObjectURL(LB_DATA._blobUrl);}catch(e){}}
  LB_DATA=null;
}
function lbDownload(){
  if(!LB_DATA)return;
  try{
    if(LB_DATA._blobUrl){
      var a2=document.createElement('a');a2.href=LB_DATA._blobUrl;a2.download=LB_DATA.name;
      document.body.appendChild(a2);a2.click();setTimeout(function(){a2.remove();},500);return;
    }
    var arr=LB_DATA.dataUrl.split(','),mime=arr[0].match(/:(.*?);/)[1],
        bstr=atob(arr[1]),n=bstr.length,u8=new Uint8Array(n);
    while(n--)u8[n]=bstr.charCodeAt(n);
    var blob=new Blob([u8],{type:mime}),url=URL.createObjectURL(blob);
    var a=document.createElement('a');a.href=url;a.download=LB_DATA.name;
    document.body.appendChild(a);a.click();
    setTimeout(function(){a.remove();URL.revokeObjectURL(url);},1000);
  } catch(e){
    var a2=document.createElement('a');a2.href=LB_DATA.dataUrl;a2.download=LB_DATA.name;
    document.body.appendChild(a2);a2.click();setTimeout(function(){a2.remove();},500);
  }
}
function lbPrint(){
  if(!LB_DATA)return;
  if(LB_DATA.type==='img'){
    var w=window.open('','_blank');
    if(w){w.document.write('<!DOCTYPE html><html><body style="margin:0;display:flex;align-items:center;justify-content:center;min-height:100vh;background:#000;"><img src="'+LB_DATA.dataUrl+'" style="max-width:100%;max-height:100vh;" onload="window.print()"></body></html>');w.document.close();}
    else lbDownload();
  } else if(LB_DATA.type==='pdf'){
    try{
      var arr=LB_DATA.dataUrl.split(','),mime='application/pdf',
          bstr=atob(arr[1]),n=bstr.length,u8=new Uint8Array(n);
      while(n--)u8[n]=bstr.charCodeAt(n);
      var blob=new Blob([u8],{type:mime}),url=URL.createObjectURL(blob);
      var w2=window.open(url,'_blank');
      if(w2)setTimeout(function(){try{w2.print();}catch(e){}},1200);
      setTimeout(function(){URL.revokeObjectURL(url);},15000);
    } catch(e){lbDownload();}
  } else {showToast('Descarga el archivo para imprimir');lbDownload();}
}
function openLBFromKey(key){
  var d=window[key];if(!d){showToast('Archivo no disponible');return;}
  openLightboxDirect(d.dataUrl,d.name,d.type);
}

