function esc(s){return s?String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'):''}
function fmtN(n){if(!n&&n!==0)return'0';if(n>=1000)return(n/1000).toFixed(1).replace(/\.0$/,'')+'K';return n.toLocaleString();}
function fmtM(n){return Number(n||0).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g,',');}
function fmtD(ds){if(!ds)return'';var d=new Date(ds+'T12:00:00');return d.toLocaleDateString('es-ES',{day:'numeric',month:'short'});}
function ago(ts){var d=Date.now()-ts,m=Math.floor(d/60000),h=Math.floor(d/3600000),dy=Math.floor(d/86400000);if(dy>0)return'hace '+dy+'d';if(h>0)return'hace '+h+'h';if(m>0)return'hace '+m+'min';return'ahora';}
function formatNoteDate(ts){
  if(!ts)return'';
  var d=new Date(ts),now=new Date(),diff=Math.floor((now-d)/86400000);
  if(diff===0){var h=d.getHours(),m=String(d.getMinutes()).padStart(2,'0'),ap=h>=12?'PM':'AM';return'Hoy '+(h%12||12)+':'+m+' '+ap;}
  if(diff===1)return'Ayer';
  return d.toLocaleDateString('es-PA',{month:'short',day:'numeric'});
}
function formatBytes(b){if(b<1024)return b+'B';if(b<1048576)return(b/1024).toFixed(1)+'KB';return(b/1048576).toFixed(1)+'MB';}
