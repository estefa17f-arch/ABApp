var _activeTheme = localStorage.getItem('abg-theme') || 'aurora';

function applyTheme(k) {
  var t = THEMES[k]; if (!t) return;
  var root = document.documentElement;
  var app  = document.getElementById('app');
  Object.keys(t.vars).forEach(function (v) {
    if (v === '--app-bg') {
      // FIX: aplicar fondo tanto al body como al app para cubrir todo
      document.body.style.background = t.vars[v];
      app.style.background           = 'inherit';
      root.style.setProperty(v, t.vars[v]);
    } else {
      root.style.setProperty(v, t.vars[v]);
    }
  });
  _activeTheme = k;
  localStorage.setItem('abg-theme', k);
  // FIX: NO llamar closeM() aquí — el usuario puede querer ver el cambio en vivo
  showToast('Tema: ' + t.label + ' aplicado ✓');
}

