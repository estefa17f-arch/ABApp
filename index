        '<button class="bd" onclick="delNoteDet(\'' + d.id + '\')">' + IC.trash + ' Eliminar</button>';
    }

    default: return '<p style="color:var(--tll);font-size:13px;padding:20px 0;">No disponible</p>';
  }
