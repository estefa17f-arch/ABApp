  --c-pink-bg:#f8d0e5;  --c-pink-tx:#7a1848;

  /* nav/fab — sobreescritos por tema */
  --nav-active: linear-gradient(135deg,#3a8fc9,#8860c8);
  --fab-bg:     linear-gradient(135deg,#3a8fc9,#8860c8);
  --app-bg:     linear-gradient(160deg,#e4f2ff 0%,#ede8ff 45%,#e4fff5 100%);

