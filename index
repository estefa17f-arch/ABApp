async function buildNotifPanel() {
  var tasks = await GA('tasks'), invs = await GA('invoices'), items = [];
  tasks.filter(function (t) { return t.status !== 'done' && t.priority === 'high'; }).slice(0, 3)
    .forEach(function (t) { items.push({ title: 'Tarea urgente', desc: t.title, ci: '4' }); });
  invs.filter(function (i) { return i.status === 'overdue'; }).slice(0, 2)
    .forEach(function (i) { items.push({ title: 'Factura vencida', desc: i.client + ' · $' + fmtM(calcInvTotals(i).total), ci: '4' }); });
  var pending = invs.filter(function (i) { return i.status === 'pending'; });
  if (pending.length) items.push({ title: pending.length + ' factura' + (pending.length > 1 ? 's' : '') + ' pendiente' + (pending.length > 1 ? 's' : ''), desc: 'Requieren seguimiento', ci: '5' });
  var cnt = document.getElementById('notif-list');
  var dot = document.getElementById('notif-dot');
  if (!items.length) {
    cnt.innerHTML = '<div style="padding:22px;text-align:center;font-size:12px;color:var(--tll);font-weight:600;">Sin notificaciones nuevas</div>';
    if (dot) dot.style.display = 'none';
  } else {
    cnt.innerHTML = items.map(function (it) {
      return '<div style="padding:12px 16px;border-bottom:1px solid rgba(160,185,210,.1);display:flex;gap:10px;">' +
        '<div style="width:8px;height:8px;border-radius:50%;background:var(--a' + it.ci + ');flex-shrink:0;margin-top:4px;"></div>' +
        '<div><div style="font-size:11px;font-weight:800;">' + esc(it.title) + '</div>' +
        '<div style="font-size:10px;color:var(--tll);">' + esc(it.desc) + '</div></div></div>';
    }).join('');
    if (dot) dot.style.display = 'block';
  }
}
