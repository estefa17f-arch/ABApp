    grid.innerHTML = '<div class="emp" style="grid-column:1/-1;"><div class="emp-t">Sin carpetas</div><div class="emp-d">Toca + para crear una carpeta</div></div>';
    return;
  }
  var files = await GA('arch-files');
  var html  = '';
  for (var i = 0; i < fil.length; i++) {
    var f   = fil[i], ci = i % 5, col = FCOLS[ci];
    var ff  = files.filter(function (x) { return x.folderId === f.id; });
    html += '<div class="arch-folder" style="background:' + col.bg + ';" onclick="openFolderDetail(\'' + f.id + '\')">' +
      '<div class="af-top" style="background:' + col.top + ';"></div>' +
