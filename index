<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, addDoc, setDoc, getDoc, getDocs, deleteDoc, doc, onSnapshot, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
const firebaseConfig = {
  apiKey:"AIzaSyA4Zaiw8U5Ld8G4gCxCK4kEMfXmHgdFb_E",
  authDomain:"abgroup-db7ea.firebaseapp.com",
  projectId:"abgroup-db7ea",
  storageBucket:"abgroup-db7ea.firebasestorage.app",
  messagingSenderId:"266741962255",
  appId:"1:266741962255:web:0ebbb27c597bb8f4c9357a"
};
const fbApp = initializeApp(firebaseConfig);
const db = getFirestore(fbApp);
async function fbGetAll(col){const snap=await getDocs(collection(db,col));return snap.docs.map(d=>({id:d.id,...d.data()}));}
async function fbGet(col,id){const snap=await getDoc(doc(db,col,String(id)));return snap.exists()?{id:snap.id,...snap.data()}:null;}
async function fbAdd(col,data){const ref=await addDoc(collection(db,col),{...data,_ts:serverTimestamp()});return ref.id;}
async function fbSet(col,id,data){await setDoc(doc(db,col,String(id)),{...data,_ts:serverTimestamp()});return id;}
async function fbDel(col,id){await deleteDoc(doc(db,col,String(id)));}
function fbListen(col,cb){return onSnapshot(collection(db,col),snap=>{cb(snap.docs.map(d=>({id:d.id,...d.data()})));});}
window.FB={fbGetAll,fbGet,fbAdd,fbSet,fbDel,fbListen,db};
window._fbReady=true;
document.dispatchEvent(new Event('fb-ready'));
</script>

<style>
:root{
  --a1:#3a8fc9;--a2:#8860c8;--a3:#4cc98a;--a4:#e8834a;--a5:#c8a820;
  --a1m:#5fa8d3;--a3m:#6dd9a8;
  --bg:#edf2f7;--sf:rgba(255,255,255,.75);--tx:#3d4a5c;--tl:#6b7a8d;--tll:#a0aec0;
  --sd:rgba(160,185,210,.45);--sl:rgba(255,255,255,.92);
  --c-green-bg:#d0f0e2;--c-green-tx:#1a6040;
  --c-blue-bg:#cce5f5;--c-blue-tx:#1a4a78;
  --c-peach-bg:#fde0c8;--c-peach-tx:#7a3820;
  --c-lav-bg:#e2d4f5;--c-lav-tx:#4a2880;
  --c-yel-bg:#f6efc0;--c-yel-tx:#6a5010;
  --c-pink-bg:#f8d0e5;--c-pink-tx:#7a1848;
  --nav-active:linear-gradient(135deg,var(--a1),var(--a2));
  --fab-bg:linear-gradient(135deg,var(--a1),var(--a2));
  --app-bg:linear-gradient(160deg,#e4f2ff 0%,#ede8ff 45%,#e4fff5 100%);
  --nav-h:calc(72px + env(safe-area-inset-bottom));
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{height:100%;}
html::before{content:'';position:fixed;top:0;left:0;right:0;bottom:0;background:var(--app-bg);z-index:-1;}
body{margin:0;padding:0;width:100%;height:100%;overflow:hidden;background:transparent;font-family:'DM Sans',sans-serif;color:var(--tx);}
#app{display:flex;flex-direction:column;position:fixed;top:0;left:0;right:0;bottom:0;width:100%;overflow:hidden;background:transparent;box-sizing:border-box;}

/* SYNC */
#sync-bar{position:absolute;top:0;left:0;right:0;height:3px;z-index:999;background:linear-gradient(90deg,var(--a1),var(--a3));transform:scaleX(0);transform-origin:left;transition:transform .4s ease;pointer-events:none;}
#sync-bar.active{transform:scaleX(1);}
#sync-badge{position:absolute;top:calc(env(safe-area-inset-top) + 8px);left:50%;transform:translateX(-50%);padding:3px 12px;border-radius:10px;font-size:9px;font-weight:800;z-index:200;display:flex;align-items:center;gap:4px;pointer-events:none;transition:opacity .4s;white-space:nowrap;}
#sync-badge.online{background:var(--c-green-bg);color:var(--c-green-tx);}
#sync-badge.offline{background:rgba(220,60,60,.12);color:#b03030;}
#sync-badge.syncing{background:var(--c-blue-bg);color:var(--c-blue-tx);}

/* SCREENS */
.scr{display:none;flex-direction:column;flex:1;overflow:hidden;padding-top:env(safe-area-inset-top);}
.scr.on{display:flex;animation:fu .3s ease;}
@keyframes fu{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.sp{flex:1;overflow-y:scroll;-webkit-overflow-scrolling:touch;padding-bottom:calc(var(--nav-h) + 16px);min-height:0;}
.sp::-webkit-scrollbar{display:none;}

/* CARDS */
.card{background:var(--sf);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,.88);border-radius:22px;box-shadow:0 6px 28px var(--sd),0 1px 6px rgba(160,185,210,.15);transition:transform .25s;position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.95),transparent);}
.neu-in{background:var(--bg);box-shadow:inset 4px 4px 10px var(--sd),inset -4px -4px 10px var(--sl);border-radius:16px;}

/* HEADER */
.hdr{padding:12px 20px 8px;display:flex;justify-content:space-between;align-items:flex-start;flex-shrink:0;}
.logo{font-family:'DM Serif Display',serif;font-size:22px;font-weight:400;background:linear-gradient(135deg,var(--a1),var(--a2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.hbts{display:flex;gap:9px;align-items:center;}
.ibtn{width:40px;height:40px;border-radius:50%;background:var(--bg);border:none;cursor:pointer;box-shadow:4px 4px 10px var(--sd),-3px -3px 8px var(--sl);display:flex;align-items:center;justify-content:center;color:var(--a1);}
.avbtn{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--a2),var(--a1));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:14px;cursor:pointer;border:2.5px solid rgba(255,255,255,.8);box-shadow:0 4px 14px rgba(0,0,0,.18);}
.ndot{width:8px;height:8px;background:var(--a4);border-radius:50%;position:absolute;top:6px;right:6px;border:2px solid var(--bg);}

/* NAV */
.bnav{position:absolute;bottom:0;left:0;right:0;height:var(--nav-h);padding:8px 14px;padding-bottom:calc(8px + env(safe-area-inset-bottom));z-index:50;background:transparent;}
.ninner{background:rgba(255,255,255,.88);backdrop-filter:blur(22px);border:1px solid rgba(255,255,255,.95);border-radius:28px;box-shadow:0 8px 36px var(--sd);display:flex;align-items:center;padding:6px;height:56px;}
.nav-track{display:flex;overflow-x:auto;scroll-behavior:smooth;flex:1;gap:2px;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.nav-track::-webkit-scrollbar{display:none;}
.ni{display:flex;flex-direction:column;align-items:center;gap:2px;cursor:pointer;padding:5px 10px;border-radius:16px;transition:all .22s;flex-shrink:0;}
.ni.on{background:var(--nav-active);box-shadow:0 4px 12px rgba(0,0,0,.18);}
.ni-i{font-size:18px;line-height:1;display:flex;align-items:center;justify-content:center;}
.ni-l{font-size:8px;font-weight:700;color:var(--tll);white-space:nowrap;}
.ni.on .ni-i{transform:scale(1.12);}
.ni.on .ni-l{color:#fff;}
.nav-arr{width:28px;height:28px;border-radius:50%;border:none;cursor:pointer;background:rgba(255,255,255,.7);box-shadow:2px 2px 6px var(--sd);display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--tx);flex-shrink:0;transition:opacity .2s;}
.nav-arr:active{transform:scale(.9);}

/* FAB */
.fab{position:absolute;bottom:calc(var(--nav-h) + 10px);right:max(20px,calc(env(safe-area-inset-right) + 20px));width:52px;height:52px;border-radius:50%;border:none;cursor:pointer;background:var(--fab-bg);color:#fff;font-size:24px;box-shadow:0 6px 22px rgba(0,0,0,.22);display:flex;align-items:center;justify-content:center;z-index:45;}
.fab:active{transform:scale(.9);}
.hdr-fab{display:none;width:40px;height:40px;border-radius:50%;border:none;cursor:pointer;background:var(--fab-bg);color:#fff;font-size:22px;align-items:center;justify-content:center;box-shadow:0 4px 14px rgba(0,0,0,.2);flex-shrink:0;}

/* TABS */
.tabs{display:flex;gap:8px;padding:0 20px;margin-bottom:12px;flex-shrink:0;overflow-x:auto;}
.tabs::-webkit-scrollbar{display:none;}
.tab{padding:7px 15px;border-radius:20px;font-size:12px;font-weight:700;cursor:pointer;border:none;background:rgba(255,255,255,.6);color:var(--tl);white-space:nowrap;box-shadow:2px 2px 6px var(--sd),-1px -1px 5px var(--sl);}
.tab.on{background:var(--nav-active);color:#fff;box-shadow:0 4px 12px rgba(0,0,0,.16);}

/* PILLS */
.prow{display:flex;gap:10px;padding:0 20px;margin-bottom:8px;overflow-x:auto;}
.prow::-webkit-scrollbar{display:none;}
.pill{flex-shrink:0;padding:9px 14px;border-radius:40px;display:flex;align-items:center;gap:7px;border:1px solid rgba(255,255,255,.85);box-shadow:0 4px 14px var(--sd);}
.p-t{font-size:11px;font-weight:700;}.p-v{font-size:11px;font-weight:900;}

/* METRIC CARDS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:0 20px;margin-bottom:8px;}
.g2 .wide{grid-column:1/-1;}
.mc{padding:17px;}.ml{font-size:10px;font-weight:800;letter-spacing:.7px;text-transform:uppercase;opacity:.65;margin-bottom:6px;}
.mv{font-size:26px;font-weight:900;line-height:1;margin-bottom:3px;}.ms{font-size:10px;opacity:.6;font-weight:600;}
.circ{position:relative;width:60px;height:60px;margin-left:auto;margin-top:-6px;}
.circ svg{width:60px;height:60px;transform:rotate(-90deg);}
.cbg{fill:none;stroke:rgba(0,0,0,.07);stroke-width:6;}
.cfl{fill:none;stroke-width:6;stroke-linecap:round;stroke-dasharray:158;stroke-dashoffset:158;transition:stroke-dashoffset 1.1s cubic-bezier(.34,1.56,.64,1);}
.cpct{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:12px;font-weight:800;}
.bw{height:7px;background:rgba(0,0,0,.07);border-radius:8px;overflow:hidden;margin-top:10px;}
.bf{height:100%;border-radius:8px;width:0;transition:width 1.1s cubic-bezier(.34,1.56,.64,1);}

/* INSIGHT */
.ins{margin:0 20px 12px;padding:14px 16px;border-radius:20px;background:linear-gradient(135deg,var(--c-blue-bg),var(--c-lav-bg));border:1px solid rgba(255,255,255,.9);display:flex;align-items:center;gap:13px;cursor:pointer;}
.ins-i{flex-shrink:0;color:var(--a1);}.ins-b{flex:1;}.ins-t{font-size:12px;font-weight:800;margin-bottom:2px;}.ins-d{font-size:10px;color:var(--tl);font-weight:600;}.ins-a{font-size:18px;color:var(--a1m);}

/* TIMELINE */
.tli{display:flex;gap:12px;padding:0 20px;margin-bottom:12px;}
.tdc{display:flex;flex-direction:column;align-items:center;flex-shrink:0;}
.td{width:9px;height:9px;border-radius:50%;margin-top:7px;}
.tln{width:2px;flex:1;min-height:20px;background:linear-gradient(to bottom,rgba(0,0,0,.07),transparent);margin-top:3px;}
.tbd{flex:1;}.tlc{padding:11px 14px;}.tlt{font-size:12px;font-weight:700;margin-bottom:2px;}.tld{font-size:10px;color:var(--tll);font-weight:600;}.tlm{font-size:9px;font-weight:700;color:var(--tll);margin-top:3px;}

/* CALENDAR */
.cnav{display:flex;align-items:center;justify-content:space-between;padding:0 20px;margin-bottom:12px;flex-shrink:0;}
.cml{font-size:19px;font-weight:800;}
.cnb{width:34px;height:34px;border-radius:50%;background:var(--bg);border:none;cursor:pointer;box-shadow:3px 3px 8px var(--sd),-2px -2px 6px var(--sl);font-size:15px;display:flex;align-items:center;justify-content:center;color:var(--tx);}
.cdh{display:grid;grid-template-columns:repeat(7,1fr);padding:0 20px;margin-bottom:6px;}
.cdh span{font-size:10px;font-weight:700;color:var(--tll);text-align:center;padding:4px 0;}
.cgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;padding:0 20px;margin-bottom:10px;}
.cday{aspect-ratio:1;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;cursor:pointer;position:relative;transition:all .18s;}
.cday.oth{color:var(--tll);}.cday.today{background:var(--nav-active);color:#fff;font-weight:800;box-shadow:0 4px 10px rgba(0,0,0,.18);}
.cday.sel:not(.today){background:color-mix(in srgb,var(--a1) 18%,transparent);font-weight:800;}
.cday.hev::after{content:'';width:4px;height:4px;border-radius:50%;background:var(--a4);position:absolute;bottom:2px;}
.tev{display:flex;gap:12px;margin:0 20px 10px;align-items:stretch;}
.tet{font-size:10px;font-weight:700;color:var(--tll);width:42px;flex-shrink:0;padding-top:12px;text-align:right;}
.ter{display:flex;flex-direction:column;align-items:center;flex-shrink:0;}
.ted{width:9px;height:9px;border-radius:50%;flex-shrink:0;border:2px solid var(--bg);}
.tel{width:2px;flex:1;min-height:8px;}
.tec{flex:1;border-radius:15px;padding:11px 13px;cursor:pointer;transition:transform .18s;}
.tec:active{transform:scale(.98);}
.tect{font-size:12px;font-weight:700;}.tecd{font-size:10px;opacity:.65;margin-top:2px;}

/* TASKS */
.ti{background:var(--sf);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.88);border-radius:17px;box-shadow:0 3px 16px rgba(160,185,210,.16);padding:14px 16px;display:flex;align-items:flex-start;gap:12px;cursor:pointer;transition:transform .18s;margin:0 20px 9px;}
.tck{width:22px;height:22px;border-radius:50%;border:2.5px solid;flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:all .2s;}
.tck.done{color:#fff;}
.tinf{flex:1;min-width:0;}.tttl{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}.tttl.done{text-decoration:line-through;opacity:.45;}
.tmeta{display:flex;gap:7px;align-items:center;margin-top:3px;flex-wrap:wrap;}
.ttag{font-size:9px;font-weight:800;padding:2px 7px;border-radius:9px;}.tdue{font-size:9px;font-weight:600;color:var(--tll);}
.tprio{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.tdel{background:none;border:none;cursor:pointer;opacity:.3;padding:2px;margin-top:1px;display:flex;align-items:center;}

/* KANBAN */
.kw{display:flex;gap:10px;padding:0 20px;overflow-x:auto;}
.kw::-webkit-scrollbar{display:none;}
.kc{flex-shrink:0;width:190px;border-radius:18px;padding:12px 10px;background:rgba(255,255,255,.55);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.9);}
.kh{display:flex;align-items:center;gap:7px;margin-bottom:10px;}
.kd{width:9px;height:9px;border-radius:50%;}.kt{font-size:11px;font-weight:800;}
.kn{margin-left:auto;width:18px;height:18px;border-radius:50%;background:rgba(0,0,0,.08);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;}
.kcard{background:rgba(255,255,255,.88);border-radius:12px;padding:9px 11px;margin-bottom:7px;cursor:pointer;}
.kct{font-size:11px;font-weight:700;margin-bottom:5px;}
.kb{height:3px;border-radius:3px;background:rgba(0,0,0,.07);margin-bottom:5px;overflow:hidden;}
.kbf{height:100%;border-radius:3px;}
.km{display:flex;justify-content:space-between;align-items:center;}.kp{font-size:9px;font-weight:700;color:var(--tll);}

/* SEARCH BAR */
.sbar{margin:0 20px 12px;padding:11px 16px;display:flex;gap:9px;align-items:center;}

/* CLIENTS */
.citem{background:var(--sf);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.88);border-radius:18px;box-shadow:0 3px 16px rgba(160,185,210,.16);padding:14px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:transform .18s;margin:0 20px 9px;}
.cav{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:15px;color:#fff;flex-shrink:0;}
.cn{font-size:14px;font-weight:800;}.cc{font-size:11px;color:var(--tll);font-weight:600;}
.cst{font-size:9px;font-weight:800;padding:3px 9px;border-radius:10px;margin-left:auto;flex-shrink:0;}
.sa{background:var(--c-green-bg);color:var(--c-green-tx);}.sl2{background:var(--c-yel-bg);color:var(--c-yel-tx);}.si{background:rgba(200,180,180,.25);color:#805050;}
.cdel{background:none;border:none;cursor:pointer;opacity:.3;padding:2px;flex-shrink:0;display:flex;align-items:center;}

/* FINANCE */
.fsum{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin-bottom:10px;flex-shrink:0;padding:0 20px;}
.fcard{padding:12px 10px;text-align:center;border-radius:17px;}
.fl{font-size:9px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;opacity:.65;margin-bottom:5px;}
.fv{font-size:17px;font-weight:900;}.fc{font-size:8px;font-weight:700;margin-top:2px;}
.chw{padding:0 20px;margin-bottom:12px;}.chc{padding:16px 14px;}
.bch{display:flex;gap:7px;align-items:flex-end;height:85px;}
.bcc{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;}
.bcb{width:100%;border-radius:7px 7px 4px 4px;}.bcl{font-size:8px;font-weight:700;color:var(--tll);}

/* INVOICE ITEMS */
.inv-item-row{display:flex;gap:7px;align-items:center;padding:8px 0;border-bottom:1px solid rgba(160,185,210,.1);}
.inv-item-row:last-child{border-bottom:none;}
.inv-item-num{font-size:10px;font-weight:800;color:var(--tll);min-width:16px;text-align:right;flex-shrink:0;}
.inv-item-in{flex:1;border:none;background:rgba(255,255,255,.7);border-radius:10px;padding:8px 10px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:600;color:var(--tx);outline:none;border:1px solid rgba(160,185,210,.2);}
.inv-item-amt{width:88px;flex-shrink:0;border:none;background:rgba(255,255,255,.7);border-radius:10px;padding:8px 10px;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;color:var(--tx);outline:none;border:1px solid rgba(160,185,210,.2);text-align:right;}
.inv-item-del{background:none;border:none;cursor:pointer;opacity:.25;display:flex;align-items:center;flex-shrink:0;}
.inv-items-wrap{border:1px solid rgba(160,185,210,.25);border-radius:14px;background:rgba(255,255,255,.75);overflow:hidden;margin-bottom:6px;}
.inv-add-btn{width:100%;padding:9px;border:none;background:transparent;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;color:var(--a1);display:flex;align-items:center;justify-content:center;gap:5px;border-top:1px dashed rgba(160,185,210,.2);}
.inv-totals{background:rgba(255,255,255,.6);border:1px solid rgba(160,185,210,.2);border-radius:12px;padding:10px 14px;margin-bottom:14px;}
.inv-total-row{display:flex;justify-content:space-between;align-items:center;padding:3px 0;}
.inv-total-lbl{font-size:11px;font-weight:700;color:var(--tl);}
.inv-total-val{font-size:12px;font-weight:800;color:var(--tx);}
.inv-total-row.grand{border-top:1.5px solid rgba(160,185,210,.3);margin-top:4px;padding-top:7px;}
.inv-total-row.grand .inv-total-lbl{font-size:13px;font-weight:800;color:var(--tx);}
.inv-total-row.grand .inv-total-val{font-size:15px;font-weight:900;color:var(--a1);}

/* INVOICES LIST */
.iitem{background:var(--sf);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.88);border-radius:17px;box-shadow:0 3px 16px rgba(160,185,210,.16);padding:13px 16px;display:flex;align-items:center;gap:11px;cursor:pointer;margin:0 20px 9px;transition:transform .15s;}
.iico{width:38px;height:38px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.iin{flex:1;min-width:0;}.inm{font-size:13px;font-weight:700;color:var(--a1);}.idt{font-size:10px;color:var(--tll);font-weight:600;}
.irt{text-align:right;flex-shrink:0;}.iamt{font-size:15px;font-weight:900;}
.ist{font-size:8px;font-weight:800;padding:2px 7px;border-radius:9px;display:inline-block;margin-top:3px;}
.spaid{background:var(--c-green-bg);color:var(--c-green-tx);}.spend{background:var(--c-yel-bg);color:var(--c-yel-tx);}.sover{background:rgba(240,80,80,.15);color:#b03030;}
.idel{background:none;border:none;cursor:pointer;opacity:.3;padding:2px;flex-shrink:0;display:flex;align-items:center;}

/* EXPENSES */
.eitem{background:var(--sf);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.88);border-radius:17px;box-shadow:0 3px 16px rgba(160,185,210,.16);padding:13px 16px;display:flex;align-items:center;gap:11px;margin:0 20px 9px;}
.eico{width:38px;height:38px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.ein{flex:1;}.enm{font-size:13px;font-weight:700;}.ect{font-size:10px;color:var(--tll);font-weight:600;}.eamt{font-size:15px;font-weight:900;color:var(--a4);}
.edel{background:none;border:none;cursor:pointer;opacity:.3;padding:2px;display:flex;align-items:center;}

/* ATTACHMENTS */
.aitem{background:var(--sf);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.88);border-radius:17px;box-shadow:0 3px 16px rgba(160,185,210,.16);padding:12px 16px;display:flex;align-items:center;gap:11px;cursor:pointer;margin:0 20px 9px;transition:transform .15s;}
.athumb{width:52px;height:52px;border-radius:12px;object-fit:cover;flex-shrink:0;}
.athumb-pdf{width:52px;height:52px;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(220,60,60,.1);color:#c03030;}
.ain{flex:1;min-width:0;}.anm{font-size:13px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}.adt{font-size:10px;color:var(--tll);font-weight:600;margin-top:2px;}
.adel{background:none;border:none;cursor:pointer;opacity:.3;padding:2px;flex-shrink:0;display:flex;align-items:center;}
.upzone{margin:0 20px 12px;border:2px dashed color-mix(in srgb,var(--a1) 40%,transparent);border-radius:20px;padding:20px;display:flex;flex-direction:column;align-items:center;gap:8px;cursor:pointer;background:color-mix(in srgb,var(--a1) 5%,transparent);}
.upzone:hover,.upzone.drag{border-color:var(--a1);background:color-mix(in srgb,var(--a1) 12%,transparent);}
.upzone-t{font-size:12px;font-weight:800;color:var(--tl);}.upzone-s{font-size:10px;font-weight:600;color:var(--tll);}

/* NOTES */
.ngrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;padding:0 20px;}
.ngrid .wide{grid-column:1/-1;}
.ncard{border-radius:24px;padding:20px 18px 42px;cursor:pointer;transition:transform .2s;min-height:160px;position:relative;border:none;}
.ncard:active{transform:scale(.96);}
.ntt{font-size:16px;font-weight:800;margin-bottom:8px;line-height:1.3;color:#2d3748;}
.npv{font-size:13px;font-weight:500;line-height:1.6;color:#4a5568;opacity:.85;}
.npv.checklist-preview{font-size:12px;line-height:1.8;}
.npv.checklist-preview .cl-item{display:flex;align-items:flex-start;gap:6px;}
.npv.checklist-preview .cl-bullet{flex-shrink:0;margin-top:2px;}
.ndt{font-size:10px;font-weight:600;color:#718096;position:absolute;bottom:14px;left:18px;}
.ndel{position:absolute;top:12px;right:12px;background:none;border:none;cursor:pointer;opacity:.25;display:flex;align-items:center;}
.npin{position:absolute;top:12px;left:12px;font-size:14px;}

/* NOTE DETAIL CHECKLIST */
.note-checklist-body{font-size:13px;line-height:1;}
.note-checklist-body .cl-item{display:flex;align-items:flex-start;gap:9px;padding:6px 0;border-bottom:1px solid rgba(160,185,210,.12);}
.note-checklist-body .cl-item:last-child{border-bottom:none;}
.note-checklist-body .cl-idx{flex-shrink:0;font-size:11px;font-weight:800;color:var(--tll);min-width:18px;text-align:right;padding-top:1px;}
.note-checklist-body .cl-bullet{flex-shrink:0;font-size:14px;padding-top:0;}
.note-checklist-body .cl-text{flex:1;font-weight:600;line-height:1.5;}

/* CHECKLIST EDITOR */
.cl-editor{width:100%;border:1px solid rgba(160,185,210,.25);border-radius:14px;background:rgba(255,255,255,.75);overflow:hidden;}
.cl-editor-row{display:flex;align-items:center;gap:8px;padding:8px 12px;border-bottom:1px solid rgba(160,185,210,.1);}
.cl-editor-row:last-child{border-bottom:none;}
.cl-editor-num{font-size:11px;font-weight:800;color:var(--tll);min-width:18px;text-align:right;flex-shrink:0;}
.cl-editor-bullet{flex-shrink:0;font-size:13px;}
.cl-editor-in{flex:1;border:none;background:transparent;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;color:var(--tx);outline:none;padding:2px 0;}
.cl-editor-del{background:none;border:none;cursor:pointer;opacity:.25;display:flex;align-items:center;flex-shrink:0;padding:2px;}
.cl-add-btn{width:100%;padding:10px;border:none;background:transparent;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:700;color:var(--a1);display:flex;align-items:center;justify-content:center;gap:5px;border-top:1px dashed rgba(160,185,210,.2);}

/* PROJECTS */
.proj-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;padding:0 20px;margin-bottom:8px;}
.proj-book{position:relative;border-radius:20px;overflow:hidden;cursor:pointer;min-height:155px;border:1px solid rgba(255,255,255,.9);box-shadow:0 6px 24px var(--sd);transition:transform .2s;background:var(--sf);}
.proj-book:active{transform:scale(.97);}
.pb-spine{position:absolute;left:0;top:0;bottom:0;width:10px;}
.pb-body{padding:14px 12px 14px 20px;height:100%;display:flex;flex-direction:column;}
.pb-icon{font-size:20px;margin-bottom:5px;}
.pb-name{font-size:13px;font-weight:800;line-height:1.3;margin-bottom:3px;color:#2d3748;}
.pb-cat{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;opacity:.5;margin-bottom:8px;}
.pb-prog{margin-top:auto;}
.pb-pct{font-size:11px;font-weight:700;color:var(--tl);margin-bottom:3px;}
.pb-bar{height:4px;border-radius:4px;background:rgba(0,0,0,.08);overflow:hidden;}
.pb-fill{height:100%;border-radius:4px;}
.pb-steps{font-size:9px;font-weight:600;color:var(--tll);margin-top:3px;}
.pb-del{position:absolute;top:9px;right:9px;background:rgba(255,255,255,.8);border:none;cursor:pointer;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:.5;font-size:11px;}

/* PROJECT DETAIL */
.proj-detail{display:none;position:fixed;inset:0;background:var(--app-bg);z-index:80;flex-direction:column;overflow:hidden;}
.proj-detail.open{display:flex;animation:fu .25s ease;}
.pd-hdr{padding:12px 20px;padding-top:calc(12px + env(safe-area-inset-top));display:flex;align-items:center;gap:12px;flex-shrink:0;border-bottom:1px solid rgba(160,185,210,.15);}
.pd-back{width:36px;height:36px;border-radius:50%;background:var(--bg);border:none;cursor:pointer;box-shadow:3px 3px 8px var(--sd),-2px -2px 6px var(--sl);display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--tx);flex-shrink:0;}
.pd-title{font-size:17px;font-weight:800;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.pd-sp{flex:1;overflow-y:scroll;-webkit-overflow-scrolling:touch;padding-bottom:calc(var(--nav-h) + 16px);}
.pd-sp::-webkit-scrollbar{display:none;}

/* VERTICAL TIMELINE */
.vtl{padding:0 20px 20px;position:relative;}
.vtl-step{display:flex;gap:12px;position:relative;z-index:1;}
.vtl-left{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:34px;}
.vtl-dot{width:34px;height:34px;border-radius:50%;border:3px solid var(--bg);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;flex-shrink:0;transition:all .3s;box-shadow:0 2px 8px rgba(0,0,0,.1);}
.vtl-dot.d-done{background:var(--a3);color:#fff;}
.vtl-dot.d-next{background:var(--nav-active);color:#fff;animation:nextGlow 2s ease-in-out infinite;}
.vtl-dot.d-pend{background:var(--bg);color:var(--tll);}
@keyframes nextGlow{0%,100%{box-shadow:0 0 0 0 rgba(58,143,201,.3);}50%{box-shadow:0 0 0 6px rgba(58,143,201,.15);}}
.vtl-line{width:2px;flex:1;min-height:14px;margin-top:3px;}
.vtl-body{flex:1;padding-bottom:18px;}
.vtl-card{background:var(--sf);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.88);border-radius:18px;box-shadow:0 3px 16px rgba(160,185,210,.16);overflow:hidden;}
.vtl-card.c-done{opacity:.7;}
.vtl-card-hdr{padding:13px 14px;display:flex;align-items:flex-start;gap:10px;cursor:pointer;}
.vtl-info{flex:1;min-width:0;}
.vtl-st{font-size:13px;font-weight:800;}
.vtl-sd{font-size:11px;color:var(--tl);margin-top:2px;line-height:1.4;}
.vtl-sm{display:flex;gap:7px;align-items:center;margin-top:5px;flex-wrap:wrap;}
.vtl-tag{font-size:9px;font-weight:800;padding:2px 8px;border-radius:9px;}
.vtl-chk{width:26px;height:26px;border-radius:50%;border:2.5px solid;flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.vtl-chk.ck-done{border-color:var(--a3);background:var(--a3);color:#fff;}
.vtl-chk.ck-next{border-color:var(--a1);}
.vtl-chk.ck-pend{border-color:rgba(160,185,210,.5);}
.vtl-exp{display:none;padding:0 14px 14px;border-top:1px solid rgba(160,185,210,.1);}
.vtl-note{background:rgba(255,255,255,.6);border-radius:12px;padding:10px 12px;font-size:12px;color:var(--tl);line-height:1.5;margin-bottom:10px;}
.sadj-row{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;}
.sadj-wrap{position:relative;display:inline-flex;}
.sadj-thumb{width:60px;height:60px;border-radius:10px;object-fit:cover;cursor:pointer;border:2px solid rgba(255,255,255,.8);}
.sadj-pdf{width:60px;height:60px;border-radius:10px;background:rgba(220,60,60,.1);color:#c03030;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:8px;font-weight:700;cursor:pointer;gap:2px;border:2px solid rgba(255,255,255,.8);text-align:center;padding:4px;}
.sadj-del{position:absolute;top:-5px;right:-5px;width:17px;height:17px;border-radius:50%;background:#fff;border:none;cursor:pointer;font-size:9px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 5px rgba(0,0,0,.15);color:#c03030;}
.sadj-add{width:60px;height:60px;border-radius:10px;border:2px dashed rgba(160,185,210,.5);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;background:rgba(255,255,255,.4);}
.sadj-add-t{font-size:8px;font-weight:700;color:var(--tll);}
.vtl-acts{display:flex;gap:8px;margin-top:8px;}
.vact-btn{flex:1;padding:8px;border-radius:11px;border:none;cursor:pointer;font-size:11px;font-weight:700;font-family:'DM Sans',sans-serif;display:flex;align-items:center;justify-content:center;gap:5px;}
.vact-del{background:rgba(220,60,60,.1);color:#c03030;}
.vact-edit{background:var(--c-blue-bg);color:var(--c-blue-tx);}

/* ARCHIVE */
.arch-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;padding:0 20px;margin-bottom:8px;}
.arch-folder{position:relative;border-radius:20px;cursor:pointer;min-height:130px;overflow:hidden;border:1px solid rgba(255,255,255,.9);box-shadow:0 6px 24px var(--sd);transition:transform .2s;background:var(--sf);}
.arch-folder:active{transform:scale(.97);}
.af-top{height:10px;}
.af-body{padding:12px 12px 12px;}
.af-icon{font-size:24px;margin-bottom:5px;}
.af-name{font-size:13px;font-weight:800;color:#2d3748;margin-bottom:2px;line-height:1.3;}
.af-meta{font-size:9px;font-weight:600;color:var(--tll);}
.af-del{position:absolute;top:18px;right:9px;background:rgba(255,255,255,.8);border:none;cursor:pointer;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:.5;font-size:11px;}
.arch-detail{display:none;position:fixed;inset:0;background:var(--app-bg);z-index:80;flex-direction:column;overflow:hidden;}
.arch-detail.open{display:flex;animation:fu .25s ease;}
.file-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;padding:0 20px;}
.file-item{position:relative;border-radius:14px;overflow:hidden;aspect-ratio:1;cursor:pointer;background:rgba(255,255,255,.7);border:1px solid rgba(255,255,255,.88);box-shadow:0 3px 12px rgba(160,185,210,.15);}
.file-thumb{width:100%;height:100%;object-fit:cover;}
.file-ic{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;}
.file-ic-lbl{font-size:9px;font-weight:700;text-align:center;padding:0 4px;line-height:1.2;color:var(--tl);}
.file-overlay{position:absolute;bottom:0;left:0;right:0;padding:5px 6px;background:linear-gradient(transparent,rgba(0,0,0,.45));}
.file-name{font-size:8px;font-weight:700;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block;}
.file-del{position:absolute;top:5px;right:5px;width:20px;height:20px;border-radius:50%;background:rgba(255,255,255,.9);border:none;cursor:pointer;font-size:10px;display:flex;align-items:center;justify-content:center;color:#c03030;}

/* LIGHTBOX */
#lightbox{display:none;position:fixed;inset:0;background:rgba(10,20,40,.92);backdrop-filter:blur(14px);z-index:300;flex-direction:column;}
#lightbox.open{display:flex;}
#lb-bar{width:100%;display:flex;align-items:center;justify-content:space-between;padding:14px 16px;padding-top:calc(14px + env(safe-area-inset-top));background:rgba(0,0,0,.4);flex-shrink:0;gap:8px;}
#lb-title{font-size:12px;font-weight:800;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;min-width:0;}
#lb-acts{display:flex;gap:6px;flex-shrink:0;}
.lb-btn{padding:8px 11px;border-radius:12px;border:none;cursor:pointer;font-size:11px;font-weight:800;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:4px;white-space:nowrap;}
.lb-dl{background:rgba(255,255,255,.18);color:#fff;}
.lb-print{background:var(--nav-active);color:#fff;}
.lb-close{background:rgba(255,255,255,.12);color:#fff;}
#lb-body{flex:1;width:100%;display:flex;align-items:center;justify-content:center;overflow:hidden;padding:12px;padding-bottom:calc(12px + env(safe-area-inset-bottom));}
#lb-img{max-width:100%;max-height:100%;border-radius:14px;object-fit:contain;display:none;}
#lb-pdf{width:100%;height:100%;border:none;border-radius:14px;display:none;background:#fff;}
#lb-nopreview{display:none;flex-direction:column;align-items:center;gap:14px;color:#fff;text-align:center;}

/* MODAL */
#mo{display:none;position:fixed;inset:0;background:rgba(60,80,100,.4);backdrop-filter:blur(8px);z-index:100;align-items:flex-end;justify-content:center;}
#mo.open{display:flex;animation:oin .2s ease;}
@keyframes oin{from{opacity:0}to{opacity:1}}
#mb{background:var(--bg);border-radius:28px 28px 0 0;padding:0 0 calc(20px + env(safe-area-inset-bottom));width:100%;max-width:430px;max-height:85vh;overflow-y:auto;animation:mup .32s cubic-bezier(.34,1.56,.64,1);}
#mb::-webkit-scrollbar{display:none;}
@keyframes mup{from{transform:translateY(100%)}to{transform:translateY(0)}}
.mhdr{display:flex;align-items:center;justify-content:space-between;padding:20px 22px 14px;border-bottom:1px solid rgba(160,185,210,.15);}
.mttl{font-size:17px;font-weight:800;}
.mcls{width:34px;height:34px;border-radius:50%;border:none;cursor:pointer;background:var(--bg);font-size:16px;display:flex;align-items:center;justify-content:center;}
.mbody{padding:16px 22px;}
.fg{margin-bottom:14px;}
.fl2{font-size:11px;font-weight:800;letter-spacing:.7px;text-transform:uppercase;color:var(--tll);margin-bottom:6px;display:block;}
.fi,.fsel,.fta{width:100%;padding:12px 14px;border:1px solid rgba(160,185,210,.25);border-radius:14px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;background:rgba(255,255,255,.75);color:var(--tx);box-shadow:inset 2px 2px 6px rgba(160,185,210,.18),inset -1px -1px 4px rgba(255,255,255,.8);outline:none;}
.fi:focus,.fsel:focus,.fta:focus{border-color:var(--a1m);}
.fta{resize:vertical;min-height:80px;}.fsel{appearance:none;cursor:pointer;}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.bp{width:100%;padding:14px;border-radius:16px;border:none;cursor:pointer;background:var(--nav-active);color:#fff;font-size:14px;font-weight:800;font-family:'DM Sans',sans-serif;display:flex;align-items:center;justify-content:center;gap:8px;}
.bd{width:100%;padding:12px;border-radius:14px;border:none;cursor:pointer;background:rgba(220,60,60,.12);color:#c03030;font-size:13px;font-weight:700;margin-top:10px;font-family:'DM Sans',sans-serif;display:flex;align-items:center;justify-content:center;gap:8px;}

/* TOAST */
#toast{position:fixed;bottom:calc(var(--nav-h) + 14px);left:50%;transform:translateX(-50%) translateY(40px);width:88%;max-width:380px;background:rgba(255,255,255,.95);backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,.95);border-radius:18px;padding:14px 16px;display:flex;gap:11px;align-items:center;z-index:200;opacity:0;pointer-events:none;transition:transform .38s cubic-bezier(.34,1.56,.64,1),opacity .38s ease;}
#toast.show{transform:translateX(-50%) translateY(0);opacity:1;pointer-events:auto;}
#tclose{margin-left:auto;background:none;border:none;cursor:pointer;opacity:.35;display:flex;align-items:center;}

/* PROFILE */
.phdr{display:flex;flex-direction:column;align-items:center;padding:10px 20px 20px;gap:8px;}
.pav{width:76px;height:76px;border-radius:50%;background:var(--nav-active);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:800;color:#fff;box-shadow:0 7px 24px rgba(0,0,0,.22);border:3.5px solid rgba(255,255,255,.85);}
.pnm{font-size:20px;font-weight:800;}.prl{font-size:12px;color:var(--tll);font-weight:600;}

/* SETTINGS */
.sitem{background:var(--sf);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.88);border-radius:17px;padding:14px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;margin:0 20px 9px;}
.sico{width:38px;height:38px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.slb{flex:1;font-size:13px;font-weight:700;}.sarr{color:var(--tll);font-size:16px;}
.tgl{width:42px;height:23px;border-radius:12px;background:rgba(0,0,0,.1);position:relative;cursor:pointer;transition:background .22s;}
.tgl.on{background:linear-gradient(135deg,var(--a3m),var(--a1m));}
.tknob{width:19px;height:19px;border-radius:50%;background:#fff;position:absolute;top:2px;left:2px;transition:left .22s;box-shadow:0 2px 5px rgba(0,0,0,.14);}
.tgl.on .tknob{left:21px;}

/* MISC */
.sep{height:1px;background:rgba(160,185,210,.2);margin:14px 20px;}
.seclb{font-size:11px;font-weight:800;letter-spacing:1.1px;text-transform:uppercase;color:var(--tll);padding:18px 20px 8px;}
.stitle{font-size:25px;font-weight:800;padding:0 20px 2px;}
.ssub{font-size:12px;color:var(--tll);font-weight:600;padding:0 20px 8px;}
.emp{text-align:center;padding:40px 30px;color:var(--tll);}
.emp-t{font-size:14px;font-weight:700;margin-bottom:6px;color:var(--tl);}.emp-d{font-size:12px;font-weight:600;line-height:1.5;}
.dr{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid rgba(160,185,210,.12);}
.dr:last-child{border:none;}.dl{font-size:11px;font-weight:700;color:var(--tll);}.dv{font-size:13px;font-weight:700;}

/* COLOR HELPERS */
.mint-bg{background:var(--c-green-bg)!important;color:var(--c-green-tx)!important;}
.blue-bg{background:var(--c-blue-bg)!important;color:var(--c-blue-tx)!important;}
.peach-bg{background:var(--c-peach-bg)!important;color:var(--c-peach-tx)!important;}
.lav-bg{background:var(--c-lav-bg)!important;color:var(--c-lav-tx)!important;}
.yel-bg{background:var(--c-yel-bg)!important;color:var(--c-yel-tx)!important;}
.pink-bg{background:var(--c-pink-bg)!important;color:var(--c-pink-tx)!important;}

/* NOTIF PANEL */
#notif-panel{display:none;position:fixed;top:calc(60px + env(safe-area-inset-top));right:16px;width:280px;background:rgba(255,255,255,.97);backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.95);border-radius:20px;box-shadow:0 12px 40px var(--sd);z-index:150;}

/* DESKTOP */
@media(min-width:768px){
  #app{flex-direction:row;}
  .bnav{position:relative;bottom:auto;left:auto;right:auto;width:64px;flex-shrink:0;padding:18px 8px;display:flex;flex-direction:column;justify-content:flex-start;background:rgba(255,255,255,.6);backdrop-filter:blur(22px);border-right:1px solid rgba(255,255,255,.85);height:100%;overflow:hidden;z-index:60;transition:width .28s;}
