  display:flex; align-items:center; gap:4px;
  pointer-events:none; transition:opacity .4s; white-space:nowrap;
}
#sync-badge.online  { background:var(--c-green-bg); color:var(--c-green-tx); }
#sync-badge.offline { background:rgba(220,60,60,.12); color:#b03030; }
#sync-badge.syncing { background:var(--c-blue-bg);  color:var(--c-blue-tx); }

/* ── pantallas ── */
.scr { display:none; flex-direction:column; flex:1; overflow:hidden; padding-top:env(safe-area-inset-top); }
.scr.on { display:flex; animation:fu .3s ease; }
@keyframes fu { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

/* scroll panel */
