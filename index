function waitFB(cb){
  if(window._fbReady&&window.FB){cb();}
  else{document.addEventListener('fb-ready',cb,{once:true});}
}
function setSyncStatus(state,msg){
  var b=document.getElementById('sync-badge'),
      bar=document.getElementById('sync-bar'),
      det=document.getElementById('fb-status-detail');
  if(state==='online'){
    b.className='online';b.innerHTML='🟢 Sincronizado';
    bar.classList.remove('active');
    setTimeout(function(){b.style.opacity='0';setTimeout(function(){b.style.display='none';},400);},2000);
  } else if(state==='offline'){
    b.style.display='flex';b.style.opacity='1';
    b.className='offline';b.innerHTML='🔴 Sin conexión';
  } else {
    b.style.display='flex';b.style.opacity='1';
    b.className='syncing';b.innerHTML='⏳ '+(msg||'Sincronizando…');
    bar.classList.add('active');
  }
  if(det) det.textContent=msg||(state==='online'?'Datos en tiempo real activos':'Sin conexión');
}
async function GA(col){return window.FB.fbGetAll(col);}
async function GO(col,id){return window.FB.fbGet(col,String(id));}
async function GP(col,data){
  setSyncStatus('syncing','Guardando…');
  var id=data.id||data._id;
  if(id){await window.FB.fbSet(col,String(id),data);setSyncStatus('online');return id;}
  var nid=await window.FB.fbAdd(col,data);setSyncStatus('online');return nid;
}
async function GD(col,id){
  setSyncStatus('syncing','Eliminando…');
  await window.FB.fbDel(col,String(id));
  setSyncStatus('online');
}
async function GAD(col,data){
  setSyncStatus('syncing','Guardando…');
  var id=await window.FB.fbAdd(col,data);
  setSyncStatus('online');return id;
}
async function logAct(icon,title,desc){
  await window.FB.fbAdd('activity',{icon:icon,title:title,desc:desc,time:Date.now()});
}

