async function saveNote() {
  var ttl = (document.getElementById('f-ttl') || {}).value.trim();
  if (!ttl) { showToast('Título requerido'); return; }
  var type   = document.getElementById('f-type').value;
  var pinTgl = document.getElementById('f-pin-tgl');
  var data   = { title: ttl, type: type, color: document.getElementById('f-col').value,
    pinned: pinTgl ? pinTgl.classList.contains('on') : false, created: Date.now() };
  if (type === 'checklist') {
    // FIX: sincronizar desde DOM antes de guardar
    _clSyncFromDOM();
    data.clItems  = _clItems.filter(Boolean);
    data.clType   = _clType;
    data.content  = data.clItems.join('\n');
  } else {
    data.content = document.getElementById('f-cont').value;
  }
  if (EID) { data.id = EID; await GP('notes', data); } else await GAD('notes', data);
  closeM(); renderNotes(); showToast(data.pinned ? 'Nota fijada 📌' : 'Nota guardada ✓');
}

