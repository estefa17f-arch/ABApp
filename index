        '<button class="bd" onclick="delClientDet(\'' + d.id + '\')">' + IC.trash + ' Eliminar</button>' : '';

    case 'event-det':
      return d ? '<div style="font-size:15px;font-weight:800;margin-bottom:14px;">' + esc(d.title) + '</div>' +
        '<div class="dr"><span class="dl">Fecha</span><span class="dv">'     + fmtD(d.date) + '</span></div>' +
