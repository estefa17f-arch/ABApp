// ── NOTAS ─────────────────────────────────────────────────
var NF = 'all';

function parseChecklist(content) {
  if (!content) return [];
  return content.split('\n')
    .filter(function (l) { return l.trim(); })
    .map(function (l) { return l.replace(/^[\-\*•\d\.]+\s*/, '').trim(); })
    .filter(Boolean);
}

function getChecklistHTML(items, type, editable) {
  if (!items || !items.length) return '';
  if (editable) {
    return items.map(function (it, i) {
      var bullet = type === 'numbered' ? (i + 1) + '.' : type === 'dot' ? '•' : '–';
      return '<div class="cl-editor-row">' +
        '<span class="cl-editor-num">'    + (type === 'numbered' ? bullet : '') + '</span>' +
        '<span class="cl-editor-bullet">' + (type !== 'numbered' ? bullet : '') + '</span>' +
        '<input class="cl-editor-in" id="cl-in-' + i + '" value="' + esc(it) + '" placeholder="Ítem ' + (i + 1) + '" oninput="_clUpdate(' + i + ',this.value)">' +
        '<button class="cl-editor-del" onclick="_clRemove(' + i + ')" title="Eliminar">✕</button>' +
        '</div>';
    }).join('');
  }
  return items.slice(0, 4).map(function (it, i) {
    var bullet = type === 'numbered' ? (i + 1) + '.' : type === 'dot' ? '•' : '–';
    return '<div class="cl-item">' +
      '<span class="cl-bullet" style="font-size:11px;font-weight:800;color:var(--tll);">' + bullet + '</span>' +
      '<span>' + esc(it) + '</span></div>';
  }).join('');
}

function getChecklistDetailHTML(items, type) {
  if (!items || !items.length) return '<div style="font-size:12px;color:var(--tll);">Sin ítems</div>';
  return items.map(function (it, i) {
    var bullet = type === 'numbered' ? (i + 1) + '.' : type === 'dot' ? '•' : '–';
    return '<div class="cl-item">' +
      '<span class="cl-idx">'    + (type === 'numbered' ? bullet : '') + '</span>' +
      '<span class="cl-bullet">' + (type !== 'numbered' ? bullet : '') + '</span>' +
      '<span class="cl-text">'   + esc(it) + '</span></div>';
  }).join('');
}

// FIX: _clItems y _clType son estado global del editor de checklist
var _clItems = [''];
var _clType  = 'bullet';

function _clUpdate(i, v) { if (_clItems[i] !== undefined) _clItems[i] = v; }
function _clRemove(i) {
  if (_clItems.length === 1) { showToast('Debe haber al menos un ítem'); return; }
  _clItems.splice(i, 1);
  var el = document.getElementById('cl-editor-inner');
  if (el) el.innerHTML = getChecklistHTML(_clItems, _clType, true);
}
function _clAdd() {
  // FIX: sincronizar desde DOM antes de agregar
  _clSyncFromDOM();
  _clItems.push('');
  var el = document.getElementById('cl-editor-inner');
  if (el) el.innerHTML = getChecklistHTML(_clItems, _clType, true);
  setTimeout(function () {
    var inp = document.getElementById('cl-in-' + (_clItems.length - 1));
    if (inp) inp.focus();
  }, 50);
}
function _clSetType(t, el) {
  // FIX: sincronizar antes de cambiar tipo para no perder valores
  _clSyncFromDOM();
  _clType = t;
  document.querySelectorAll('.cl-type-btn').forEach(function (b) {
    b.style.background = 'rgba(0,0,0,.07)'; b.style.color = 'var(--tl)';
  });
  el.style.background = 'var(--nav-active)'; el.style.color = '#fff';
  var inner = document.getElementById('cl-editor-inner');
  if (inner) inner.innerHTML = getChecklistHTML(_clItems, _clType, true);
}
// FIX: función centralizada para sincronizar inputs del DOM → _clItems
function _clSyncFromDOM() {
  for (var i = 0; i < _clItems.length; i++) {
    var inp = document.getElementById('cl-in-' + i);
    if (inp) _clItems[i] = inp.value;
  }
}

async function renderNotes() {
  var notes   = await GA('notes');
  var pinned  = notes.filter(function (n) { return n.pinned; });
  var unpinned= notes.filter(function (n) { return !n.pinned; });
  var sorted  = pinned.concat(unpinned);
  var fil;
  if      (NF === 'pinned')    fil = pinned;
  else if (NF === 'all')       fil = sorted;
  else                         fil = sorted.filter(function (n) { return n.type === NF; });

  document.getElementById('n-sub').textContent =
    notes.length + ' nota' + (notes.length !== 1 ? 's' : '') +
    (pinned.length ? ' · ' + pinned.length + ' 📌' : '');

  var cnt = document.getElementById('n-grid'); if (!cnt) return;
  if (!fil.length) { cnt.innerHTML = '<div class="emp" style="grid-column:1/-1;"><div class="emp-t">Sin notas</div></div>'; return; }

  var NC = {
    'blue-lav': 'color-mix(in srgb,var(--a1) 12%,white)',
    'mint':     'color-mix(in srgb,var(--a3) 14%,white)',
    'peach':    'color-mix(in srgb,var(--a4) 14%,white)',
    'yellow':   'color-mix(in srgb,var(--a5) 14%,white)',
    'pink':     'color-mix(in srgb,var(--a2) 12%,white)',
    'lav':      'color-mix(in srgb,var(--a2) 10%,white)'
  };

  cnt.innerHTML = fil.map(function (n) {
    var bg     = NC[n.color] || NC['yellow'];
    var isWide = n.pinned || n.type === 'project';
    var previewHtml;
    if (n.type === 'checklist') {
      var citems = n.clItems || parseChecklist(n.content);
      var ctype  = n.clType  || 'bullet';
      previewHtml = '<div class="npv checklist-preview">' +
        getChecklistHTML(citems.slice(0, 4), ctype, false) +
        (citems.length > 4 ? '<div style="font-size:10px;color:var(--tll);margin-top:3px;">+' + (citems.length - 4) + ' más</div>' : '') +
        '</div>';
    } else {
      previewHtml = '<div class="npv">' + esc((n.content || '').substring(0, 90)) +
        ((n.content || '').length > 90 ? '…' : '') + '</div>';
    }
    return '<div class="ncard' + (isWide ? ' wide' : '') + '" style="background:' + bg + ';border:1px solid rgba(255,255,255,.8);" onclick="openNDet(\'' + n.id + '\')">' +
      (n.pinned ? '<div class="npin">📌</div>' : '') +
      '<div class="ntt" style="padding-left:' + (n.pinned ? '22px' : '0') + '">' + esc(n.title) + '</div>' +
      previewHtml +
      '<div class="ndt">' + formatNoteDate(n.created) + '</div>' +
      '<button class="ndel" onclick="delNote(\'' + n.id + '\',event)">✕</button></div>';
  }).join('');
}

async function delNote(id, e) { e.stopPropagation(); await GD('notes', id); renderNotes(); }
function fNote(f, btn) {
  NF = f;
  document.querySelectorAll('#s-notes .tab').forEach(function (t) { t.classList.remove('on'); });
  btn.classList.add('on'); renderNotes();
}

