// ── LISTENERS EN TIEMPO REAL ──────────────────────────────
var _listeners = {};
function setupListeners() {
  ['tasks','clients','events','invoices','expenses','notes','activity'].forEach(function (col) {
    if (_listeners[col]) return;
    _listeners[col] = window.FB.fbListen(col, function () {
      if (CS === 'tasks')    renderTasks();
      if (CS === 'clients')  renderClients();
      if (CS === 'calendar') renderCal();
      if (CS === 'finance')  renderFin();
      if (CS === 'notes')    renderNotes();
      if (CS === 'home')     renderHome();
    });
  });
}

