           '<div style="flex:1;border-top:1px solid rgba(160,185,210,.12);padding:4px 0;min-height:26px;">';
      hevs.forEach(function (ev, j) {
        h += '<div onclick="openEvDet(\'' + ev.id + '\')" style="border-radius:12px;padding:9px 12px;margin-bottom:6px;background:color-mix(in srgb,var(--a' + ((j % 2) + 1) + ') 12%,white);cursor:pointer;border:1px solid rgba(255,255,255,.8);border-left:3px solid var(--a' + ((j % 2) + 1) + ');">' +
             '<div style="font-size:12px;font-weight:800;">' + esc(ev.title) + '</div>' +
             '<div style="font-size:10px;opacity:.7;margin-top:2px;">' + ev.time + ' · ' + ev.duration + ' min' + (ev.desc ? ' · ' + esc(ev.desc) : '') + '</div></div>';
      });
      h += '</div></div>';
    });
  }
