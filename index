function scrollNav(dir) {
  var t = document.getElementById('nav-track');
  if (t) t.scrollBy({ left: dir * 120, behavior: 'smooth' });
}
function updateNavArrows() {
  var t = document.getElementById('nav-track'); if (!t) return;
  var l = document.getElementById('nav-left'), r = document.getElementById('nav-right');
  if (l) l.style.opacity = t.scrollLeft > 4 ? '1' : '0.3';
  if (r) r.style.opacity = (t.scrollLeft + t.clientWidth < t.scrollWidth - 4) ? '1' : '0.3';
}
function checkNavArrows() {
  var l = document.getElementById('nav-left'), r = document.getElementById('nav-right');
  if (window.innerWidth >= 768) {
    if (l) l.style.display = 'none';
    if (r) r.style.display = 'none';
  } else {
    if (l) l.style.display = '';
    if (r) r.style.display = '';
    updateNavArrows();
  }
}

