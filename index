  --c-blue-bg:#cce5f5;  --c-blue-tx:#1a4a78;
  --c-peach-bg:#fde0c8; --c-peach-tx:#7a3820;
  --c-lav-bg:#e2d4f5;   --c-lav-tx:#4a2880;
