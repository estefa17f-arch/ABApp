var _pendingFile = null;
function promptFileNameAndSave(file) {
  _pendingFile = file;
  openModal('_filename');
  document.getElementById('m-ttl').textContent = 'Nombre del archivo';
  document.getElementById('m-body').innerHTML =
    '<div class="fg"><label class="fl2">Nombre personalizado</label>' +
