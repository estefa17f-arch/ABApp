async function saveInvoice() {
  var cl = (document.getElementById('f-cl') || {}).value.trim();
  if (!cl) { showToast('Cliente requerido'); return; }
  // FIX: sincronizar ítems desde DOM antes de validar
  for (var i = 0; i < _invItems.length; i++) {
    var di = document.getElementById('inv-it-d-' + i);
    var ai = document.getElementById('inv-it-a-' + i);
    if (di) _invItems[i].desc   = di.value;
    if (ai) _invItems[i].amount = parseFloat(ai.value) || 0;
  }
  var validItems = _invItems.filter(function (it) { return it.desc && Number(it.amount) > 0; });
  if (!validItems.length) { showToast('Agrega al menos un ítem con monto'); return; }
  var dPct = Number((document.getElementById('inv-disc-pct') || {}).value || 0);
  var dAmt = Number((document.getElementById('inv-disc-amt') || {}).value || 0);
  var t    = calcInvTotals({ items: validItems, discountPct: dPct, discountAmt: dAmt });
  var data = { client: cl, number: document.getElementById('f-num').value.trim(),
    items: validItems, discountPct: dPct, discountAmt: dAmt,
    amount: t.total, subtotal: t.subtotal, itbms: t.itbms, total: t.total,
    date: document.getElementById('f-date').value, due: document.getElementById('f-due').value,
    status: document.getElementById('f-st').value, created: Date.now() };
  var sid;
  if (EID) { data.id = EID; await GP('invoices', data); sid = EID; } else sid = await GAD('invoices', data);
  await renderFin(); if (CS === 'home') renderHome();
  // Mostrar resumen en modal
  document.getElementById('m-ttl').textContent = 'Factura Guardada';
  document.getElementById('m-body').innerHTML =
    '<div style="text-align:center;padding:10px 0 16px;">' +
      '<div style="font-size:16px;font-weight:800;margin-bottom:2px;">' + esc(data.number) + '</div>' +
      '<div style="font-size:13px;color:var(--tll);">' + esc(data.client) + ' · ' + validItems.length + ' ítem' + (validItems.length > 1 ? 's' : '') + '</div>' +
      (t.totalDiscount > 0 ? '<div style="font-size:11px;color:#1a8050;font-weight:700;margin-top:4px;">Descuento: -$' + fmtM(t.totalDiscount) + '</div>' : '') +
      '<div style="margin:10px auto 0;display:inline-block;padding:8px 20px;border-radius:12px;background:var(--c-green-bg);color:var(--c-green-tx);font-size:13px;font-weight:800;">Total: $' + fmtM(t.total) + '</div>' +
      '<div style="font-size:11px;color:var(--tll);margin-top:5px;">Subtotal $' + fmtM(t.subtotal) + ' + ITBMS 7% $' + fmtM(t.itbms) + '</div></div>' +
    '<button class="bp" style="margin-bottom:10px;" onclick="printInvoice(\'' + sid + '\')">' + IC.print + ' Imprimir PDF</button>' +
    '<button class="bd" onclick="closeM()">Cerrar</button>';
}

