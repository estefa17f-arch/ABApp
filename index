  transition:transform .4s ease; pointer-events:none;
}
#sync-bar.active { transform:scaleX(1); }

#sync-badge {
  position:absolute;
  top:calc(env(safe-area-inset-top) + 8px);
  left:50%; transform:translateX(-50%);
