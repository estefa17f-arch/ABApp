async function renderArchive() {
  var srch    = (document.getElementById('arch-q') || {}).value || '';
  var folders = await GA('arch-folders');
  var fil     = srch ? folders.filter(function (f) { return f.name.toLowerCase().includes(srch.toLowerCase()); }) : folders;
  document.getElementById('arch-sub').textContent = folders.length + ' carpeta' + (folders.length !== 1 ? 's' : '');
