// ── CALENDAR ─────────────────────────────────────────────
var CY  = new Date().getFullYear();
var CM_ = new Date().getMonth();
var SD  = new Date().toISOString().split('T')[0];
var MONS = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

async function renderCal() { buildCG(); renderDE(SD); }

async function buildCG() {
  document.getElementById('cal-lbl').textContent  = MONS[CM_] + ' ' + CY;
  document.getElementById('cal-sub').textContent  = MONS[CM_] + ' ' + CY;
  var fd   = new Date(CY, CM_, 1).getDay();
  var days = new Date(CY, CM_ + 1, 0).getDate();
  var pv   = new Date(CY, CM_, 0).getDate();
  var today = new Date().toISOString().split('T')[0];
  var h = '';
  for (var i = fd - 1; i >= 0; i--) h += '<div class="cday oth">' + (pv - i) + '</div>';
  for (var d = 1; d <= days; d++) {
    var ds = CY + '-' + String(CM_ + 1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
    var c  = 'cday';
    if (ds === today) c += ' today';
    else if (ds === SD) c += ' sel';
    h += '<div class="' + c + '" onclick="selDay(\'' + ds + '\',this)">' + d + '</div>';
  }
  var rem = 42 - (fd + days);
  for (var d2 = 1; d2 <= rem; d2++) h += '<div class="cday oth">' + d2 + '</div>';
  document.getElementById('cal-g').innerHTML = h;

  // marcar días con eventos
  var evs = await GA('events');
  var g   = document.getElementById('cal-g'); if (!g) return;
  evs.forEach(function (ev) {
    var dd = new Date(ev.date + 'T12:00:00');
    if (dd.getFullYear() === CY && dd.getMonth() === CM_) {
      var idx = new Date(CY, CM_, 1).getDay() + dd.getDate() - 1;
      var el  = g.children[idx];
      if (el && !el.classList.contains('today')) el.classList.add('hev');
    }
  });
}

function selDay(ds, el) {
  document.querySelectorAll('.cday.sel').forEach(function (d) { d.classList.remove('sel'); });
  if (!el.classList.contains('today')) el.classList.add('sel');
  SD = ds; renderDE(ds);
}

async function renderDE(date) {
  var evs = await GA('events');
  var de  = evs.filter(function (e) { return e.date === date; })
               .sort(function (a, b) { return (a.time || '').localeCompare(b.time || ''); });
  var cnt = document.getElementById('day-evs'); if (!cnt) return;
  if (!de.length) { cnt.innerHTML = '<div class="emp"><div class="emp-t">Sin eventos</div><div class="emp-d">Toca + para agregar</div></div>'; return; }
  cnt.innerHTML = de.map(function (ev, i) {
    var bg  = 'color-mix(in srgb,var(--a' + ((i % 4) + 1) + ') 14%,white)';
    var dot = 'var(--a' + ((i % 4) + 1) + ')';
    return '<div class="tev">' +
      '<div class="tet">' + (ev.time || '') + '</div>' +
      '<div class="ter"><div class="ted" style="background:' + dot + ';"></div>' +
      (i < de.length - 1 ? '<div class="tel" style="background:' + dot + ';opacity:.3;"></div>' : '') + '</div>' +
      '<div class="tec" style="background:' + bg + ';border:1px solid rgba(255,255,255,.9);" onclick="openEvDet(\'' + ev.id + '\')">' +
      '<div class="tect">' + esc(ev.title) + '</div>' +
      '<div class="tecd">' + esc(ev.desc || '') + ' · ' + ev.duration + 'min</div></div></div>';
  }).join('');
}

function chMon(dir) {
  CM_ += dir;
  if (CM_ > 11) { CM_ = 0; CY++; }
  if (CM_ < 0)  { CM_ = 11; CY--; }
  buildCG();
}

function setCalView(v, btn) {
  document.querySelectorAll('#s-calendar .tab').forEach(function (t) { t.classList.remove('on'); });
  btn.classList.add('on');
  var mv = document.getElementById('cal-month-view');
  var wv = document.getElementById('cal-week-view');
  var dv = document.getElementById('cal-day-view');
  mv.style.display = v === 'month' ? '' : 'none';
  wv.style.display = v === 'week'  ? 'block' : 'none';
  dv.style.display = v === 'day'   ? 'block' : 'none';
  if (v === 'week') renderWeekView();
  else if (v === 'day') renderDayView();
}

async function renderWeekView() {
  var wv = document.getElementById('cal-week-view'); if (!wv) return;
  var evs  = await GA('events');
  var base = SD ? new Date(SD + 'T12:00:00') : new Date();
  var dow  = base.getDay();
  var monday = new Date(base); monday.setDate(base.getDate() - (dow === 0 ? 6 : dow - 1));
  var days = [];
  for (var i = 0; i < 7; i++) { var dd = new Date(monday); dd.setDate(monday.getDate() + i); days.push(dd); }
  var today = new Date().toISOString().split('T')[0];
  var dn = ['Lu','Ma','Mi','Ju','Vi','Sá','Do'];
  var h = '<div style="padding:8px 0 14px;font-size:12px;font-weight:800;color:var(--tll);">Semana del ' + days[0].getDate() + ' al ' + days[6].getDate() + ' de ' + MONS[days[0].getMonth()] + '</div>' +
          '<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px;">';
  days.forEach(function (d, i) {
    var ds   = d.toISOString().split('T')[0];
    var isT  = ds === today;
    var dayEvs = evs.filter(function (e) { return e.date === ds; });
    h += '<div style="border-radius:12px;overflow:hidden;background:rgba(255,255,255,.5);border:1px solid rgba(255,255,255,.85);">' +
         '<div style="padding:5px 3px;text-align:center;font-size:9px;font-weight:800;' + (isT ? 'background:var(--nav-active);color:#fff;border-radius:8px;' : '') + '">' + dn[i] + '<br>' + d.getDate() + '</div>';
    dayEvs.forEach(function (ev, j) {
      h += '<div onclick="openEvDet(\'' + ev.id + '\')" style="margin:2px;padding:3px 4px;border-radius:6px;background:color-mix(in srgb,var(--a' + ((j % 2) + 1) + ') 18%,white);border-left:3px solid var(--a' + ((j % 2) + 1) + ');font-size:8px;font-weight:700;cursor:pointer;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">' + esc(ev.title) + '</div>';
    });
    if (!dayEvs.length) h += '<div style="padding:6px 3px;text-align:center;font-size:8px;color:var(--tll);">—</div>';
    h += '</div>';
  });
  h += '</div>';
  wv.innerHTML = h;
}

async function renderDayView() {
  var dv = document.getElementById('cal-day-view'); if (!dv) return;
  var evs    = await GA('events');
  var date   = SD || new Date().toISOString().split('T')[0];
  var dayEvs = evs.filter(function (e) { return e.date === date; })
                  .sort(function (a, b) { return (a.time || '').localeCompare(b.time || ''); });
