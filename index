  { spine: 'var(--a4)', bg: 'linear-gradient(135deg,#fff3ea,#fde8d4)' },
  { spine: 'var(--a5)', bg: 'linear-gradient(135deg,#fffbea,#fdf3c8)' }
];

async function renderProjects() {
  var projs = await GA('projects');
  var fil   = PF === 'all' ? projs : projs.filter(function (p) { return p.status === PF; });
  document.getElementById('proj-sub').textContent = projs.length + ' proyecto' + (projs.length !== 1 ? 's' : '');
  var grid  = document.getElementById('proj-grid');
  if (!fil.length) {
    grid.innerHTML = '<div class="emp" style="grid-column:1/-1;"><div class="emp-t">Sin proyectos</div><div class="emp-d">Toca + para crear tu primer proyecto</div></div>';
    return;
  }
  var steps = await GA('proj-steps');
  var html  = '';
  for (var i = 0; i < fil.length; i++) {
    var p   = fil[i], ci = i % 5, col = PCOLS[ci];
    var ps  = steps.filter(function (s) { return s.projectId === p.id; });
    var pd  = ps.filter(function (s) { return s.status === 'done'; }).length;
    var pt  = ps.length;
    var pp  = pt > 0 ? Math.round(pd / pt * 100) : 0;
    var stLbl = p.status === 'active' ? '🟢' : p.status === 'done' ? '✅' : '⏸';
    html += '<div class="proj-book" style="background:' + col.bg + ';" onclick="openProjDetail(\'' + p.id + '\')">' +
      '<div class="pb-spine" style="background:' + col.spine + ';"></div>' +
      '<div class="pb-body">' +
        '<div class="pb-icon">' + (p.emoji || '📁') + '</div>' +
        '<div class="pb-name">' + esc(p.name) + '</div>' +
        '<div class="pb-cat">'  + stLbl + ' ' + esc(p.category || 'General') + '</div>' +
        '<div class="pb-prog">' +
          '<div class="pb-pct">' + pp + '%</div>' +
          '<div class="pb-bar"><div class="pb-fill" style="width:' + pp + '%;background:' + col.spine + ';"></div></div>' +
          '<div class="pb-steps">' + pd + '/' + pt + ' pasos</div>' +
        '</div>' +
      '</div>' +
      '<button class="pb-del" onclick="delProj(\'' + p.id + '\',event)">✕</button></div>';
  }
  grid.innerHTML = html;
}

function fProj(f, btn) {
  PF = f;
  document.querySelectorAll('#s-projects .tab').forEach(function (t) { t.classList.remove('on'); });
  btn.classList.add('on'); renderProjects();
}

async function openProjDetail(id) {
  var p = await GO('projects', id); if (!p) return;
  CURR_PROJ = p;
  document.getElementById('pd-title').textContent = p.name;
  document.getElementById('pd-cat').textContent   = (p.emoji || '📁') + ' ' + (p.category || 'General');
  var stLbl = p.status === 'active' ? '🟢 Activo' : p.status === 'done' ? '✅ Finalizado' : '⏸ Pausado';
  document.getElementById('pd-stbtn').textContent = stLbl;
  document.getElementById('proj-detail').classList.add('open');
  await renderTimeline(id);
}
function closeProjDetail() {
  document.getElementById('proj-detail').classList.remove('open');
  CURR_PROJ = null; renderProjects();
}
async function cycleProjStatus() {
  if (!CURR_PROJ) return;
  var states = ['active', 'paused', 'done'];
  var ci     = states.indexOf(CURR_PROJ.status || 'active');
  CURR_PROJ.status = states[(ci + 1) % 3];
  await GP('projects', CURR_PROJ);
  var stLbl = CURR_PROJ.status === 'active' ? '🟢 Activo' : CURR_PROJ.status === 'done' ? '✅ Finalizado' : '⏸ Pausado';
  document.getElementById('pd-stbtn').textContent = stLbl;
  showToast('Estado: ' + stLbl);
}
function openAddStep() { if (CURR_PROJ) openModal('step', { projectId: CURR_PROJ.id }); }

async function renderTimeline(projId) {
  var steps = await GA('proj-steps');
  var ps    = steps.filter(function (s) { return s.projectId === projId; })
                   .sort(function (a, b) { return (a.order || 0) - (b.order || 0); });
  var pd = ps.filter(function (s) { return s.status === 'done'; }).length;
  var pt = ps.length;
  var pp = pt > 0 ? Math.round(pd / pt * 100) : 0;

  var bar = document.getElementById('pd-bar'); if (bar) bar.style.width = pp + '%';
  var sl  = document.getElementById('pd-slbl'); if (sl) sl.textContent = pd + ' de ' + pt + ' pasos';
  var pl  = document.getElementById('pd-plbl'); if (pl) pl.textContent = pp + '%';

  var nextIdx = -1;
  for (var i = 0; i < ps.length; i++) { if (ps[i].status !== 'done') { nextIdx = i; break; } }

  var cnt = document.getElementById('vtl-cnt'); if (!cnt) return;
  if (!ps.length) {
    cnt.innerHTML = '<div class="emp"><div class="emp-t">Sin pasos</div><div class="emp-d">Toca + para agregar el primer paso</div></div>';
    return;
  }

  var html = '';
  for (var j = 0; j < ps.length; j++) {
    var s      = ps[j];
    var isDone = s.status === 'done';
    var isNext = j === nextIdx;
    var dc = isDone ? 'd-done' : isNext ? 'd-next' : 'd-pend';
    var cc = isDone ? 'ck-done': isNext ? 'ck-next': 'ck-pend';
    var adjs = s.attachments || [];
    var adjHtml = '';

    for (var k = 0; k < adjs.length; k++) {
      var a     = adjs[k];
      var aIsImg= a.mime && a.mime.startsWith('image/');
      var aIsPdf= a.mime === 'application/pdf';
      var aType = aIsImg ? 'img' : aIsPdf ? 'pdf' : 'other';
      // FIX: clave única con índice de paso + índice de adjunto
      var aKey  = '_lb_step_' + s.id + '_' + k;
      window[aKey] = { dataUrl: a.dataUrl, name: a.name || 'Archivo', type: aType };
      if (aIsImg) {
        adjHtml += '<div class="sadj-wrap"><img class="sadj-thumb" src="' + a.dataUrl + '" onclick="openLBFromKey(\'' + aKey + '\')" alt="">' +
          '<button class="sadj-del" onclick="delStepAdj(\'' + s.id + '\',' + k + ',event)">✕</button></div>';
      } else {
        adjHtml += '<div class="sadj-wrap"><div class="sadj-pdf" onclick="openLBFromKey(\'' + aKey + '\')">' + IC.inv +
          '<span>' + esc((a.name || '').substring(0, 10)) + '</span></div>' +
          '<button class="sadj-del" onclick="delStepAdj(\'' + s.id + '\',' + k + ',event)">✕</button></div>';
      }
    }
    adjHtml += '<div class="sadj-add" onclick="triggerStepUpload(\'' + s.id + '\')">' +
      '<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="color:var(--a1);opacity:.5;"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6z"/></svg>' +
      '<span class="sadj-add-t">Subir</span></div>';

    var cardStyle = isNext ? 'style="box-shadow:0 0 0 3px rgba(58,143,201,.2),0 3px 16px rgba(160,185,210,.16);"' : '';
    html += '<div class="vtl-step">' +
      '<div class="vtl-left">' +
        '<div class="vtl-dot ' + dc + '">' + (isDone ? IC.check : (j + 1)) + '</div>' +
        (j < ps.length - 1 ? '<div class="vtl-line" style="background:rgba(160,185,210,.3);"></div>' : '') +
      '</div>' +
      '<div class="vtl-body">' +
        '<div class="vtl-card' + (isDone ? ' c-done' : '') + '" ' + cardStyle + '>' +
          '<div class="vtl-card-hdr" onclick="toggleStepExp(\'' + s.id + '\')">' +
            '<div class="vtl-info">' +
              '<div class="vtl-st"' + (isDone ? ' style="text-decoration:line-through;opacity:.5;"' : '') + '>' + esc(s.title) + '</div>' +
              (s.description ? '<div class="vtl-sd">' + esc(s.description) + '</div>' : '') +
              '<div class="vtl-sm">' +
                (isDone ? '<span class="vtl-tag" style="background:var(--c-green-bg);color:var(--c-green-tx);">✓ Completado</span>' :
                 isNext ? '<span class="vtl-tag" style="background:var(--c-blue-bg);color:var(--c-blue-tx);">▶ Siguiente</span>' : '') +
                (s.due  ? '<span style="font-size:9px;font-weight:600;color:var(--tll);">Vence ' + fmtD(s.due) + '</span>' : '') +
                (adjs.length ? '<span style="font-size:9px;font-weight:600;color:var(--tl);">📎 ' + adjs.length + '</span>' : '') +
              '</div>' +
            '</div>' +
            '<div class="vtl-chk ' + cc + '" onclick="togStep(\'' + s.id + '\',event)">' + (isDone ? IC.check : '') + '</div>' +
          '</div>' +
          '<div id="vstep-exp-' + s.id + '" class="vtl-exp">' +
            (s.notes ? '<div class="vtl-note">' + esc(s.notes) + '</div>' : '') +
            '<div style="font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.7px;color:var(--tll);margin-bottom:8px;">Adjuntos</div>' +
            '<div class="sadj-row" id="sadjs-' + s.id + '">' + adjHtml + '</div>' +
            '<div class="vtl-acts">' +
              '<button class="vact-btn vact-edit" onclick="editStepModal(\'' + s.id + '\')">' + IC.edit + ' Editar</button>' +
              '<button class="vact-btn vact-del"  onclick="delStep(\'' + s.id + '\',event)">' + IC.trash + ' Eliminar</button>' +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div></div>';
  }
  cnt.innerHTML = html;
}

function toggleStepExp(id) {
  var el = document.getElementById('vstep-exp-' + id);
  if (el) el.style.display = el.style.display === 'block' ? 'none' : 'block';
}
async function togStep(id, e) {
  e.stopPropagation();
  var s = await GO('proj-steps', id); if (!s) return;
  s.status = s.status === 'done' ? 'pending' : 'done';
  await GP('proj-steps', s);
  if (s.status === 'done') { await logAct('', 'Paso completado: ' + s.title, ''); showToast('Paso completado ✓'); }
  else showToast('Paso reabierto');
  await renderTimeline(s.projectId);
}
async function delStep(id, e) {
  e.stopPropagation();
  var s = await GO('proj-steps', id); if (!s) return;
  var pid = s.projectId;
  await GD('proj-steps', id); await renderTimeline(pid); showToast('Paso eliminado');
}
function triggerStepUpload(stepId) { CURR_STEP_ID = stepId; document.getElementById('step-file-input').click(); }

async function handleStepFile(e) {
  var file = e.target.files[0]; if (!file) return; e.target.value = '';
  // FIX: límite subido a 5MB (era 1MB, demasiado restrictivo para PDFs)
  if (file.size > 5 * 1024 * 1024) { showToast('Máximo 5MB por adjunto'); return; }
  showToast('Guardando…');
  var reader = new FileReader();
  reader.onload = async function (ev) {
    var s = await GO('proj-steps', CURR_STEP_ID); if (!s) return;
    s.attachments = s.attachments || [];
    s.attachments.push({ name: file.name, mime: file.type, size: file.size, dataUrl: ev.target.result });
    await GP('proj-steps', s);
    await renderTimeline(s.projectId);
    // FIX: mantener el panel expandido después de guardar
    setTimeout(function () {
      var el = document.getElementById('vstep-exp-' + CURR_STEP_ID);
      if (el) el.style.display = 'block';
    }, 150);
    showToast('Adjunto guardado ✓');
  };
  reader.readAsDataURL(file);
}

async function delStepAdj(stepId, idx, e) {
  e.stopPropagation();
  var s = await GO('proj-steps', stepId); if (!s) return;
  (s.attachments = s.attachments || []).splice(idx, 1);
  await GP('proj-steps', s);
  await renderTimeline(s.projectId);
  setTimeout(function () {
    var el = document.getElementById('vstep-exp-' + stepId);
    if (el) el.style.display = 'block';
  }, 150);
  showToast('Adjunto eliminado');
}
async function editStepModal(id) {
  var s = await GO('proj-steps', id);
  if (s) { closeM(); setTimeout(function () { openModal('step-edit', s); }, 100); }
}
async function delProj(id, e) {
  e.stopPropagation();
  var steps = await GA('proj-steps');
  var ps    = steps.filter(function (s) { return s.projectId === id; });
  for (var i = 0; i < ps.length; i++) await GD('proj-steps', ps[i].id);
  await GD('projects', id); renderProjects(); showToast('Proyecto eliminado');
}

