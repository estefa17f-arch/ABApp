/* ── reset ── */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
html { height:100%; }
body {
  margin:0; padding:0;
  width:100%; height:100%;
  overflow:hidden;
  /* FIX: fondo desde var, con fallback */
  background: var(--app-bg, linear-gradient(160deg,#e4f2ff,#ede8ff,#e4fff5));
  font-family:'DM Sans',sans-serif;
  color:var(--tx);
}

/* ── contenedor principal ── */
#app {
  display:flex; flex-direction:column;
  position:fixed; inset:0;
  overflow:hidden;
  /* FIX: hereda el fondo del body para que los temas funcionen */
  background:inherit;
}

/* ── barra de sincronización ── */
#sync-bar {
  position:absolute; top:0; left:0; right:0; height:3px; z-index:999;
  background:linear-gradient(90deg,var(--a1),var(--a3));
