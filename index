.inm   { font-size:13px; font-weight:700; color:var(--a1); }
.idt   { font-size:10px; color:var(--tll); font-weight:600; }
.irt   { text-align:right; flex-shrink:0; }
.iamt  { font-size:15px; font-weight:900; }
.ist   { font-size:8px; font-weight:800; padding:2px 7px; border-radius:9px; display:inline-block; margin-top:3px; }
.spaid { background:var(--c-green-bg); color:var(--c-green-tx); }
.spend { background:var(--c-yel-bg);   color:var(--c-yel-tx); }
.sover { background:rgba(240,80,80,.15); color:#b03030; }
.idel  { background:none; border:none; cursor:pointer; opacity:.3; padding:2px; flex-shrink:0; display:flex; align-items:center; }

.eitem {
  background:var(--sf); backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,.88); border-radius:17px;
  box-shadow:0 3px 16px rgba(160,185,210,.16);
  padding:13px 16px; display:flex; align-items:center; gap:11px; margin:0 20px 9px;
}
.eico  { width:38px; height:38px; border-radius:12px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.ein   { flex:1; }
.enm   { font-size:13px; font-weight:700; }
.ect   { font-size:10px; color:var(--tll); font-weight:600; }
.eamt  { font-size:15px; font-weight:900; color:var(--a4); }
.edel  { background:none; border:none; cursor:pointer; opacity:.3; padding:2px; display:flex; align-items:center; }

.aitem {
  background:var(--sf); backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,.88); border-radius:17px;
  box-shadow:0 3px 16px rgba(160,185,210,.16);
  padding:12px 16px; display:flex; align-items:center; gap:11px;
  cursor:pointer; margin:0 20px 9px; transition:transform .15s;
}
.athumb     { width:52px; height:52px; border-radius:12px; object-fit:cover; flex-shrink:0; }
.athumb-pdf { width:52px; height:52px; border-radius:12px; flex-shrink:0; display:flex; align-items:center; justify-content:center; background:rgba(220,60,60,.1); color:#c03030; }
.ain   { flex:1; min-width:0; }
.anm   { font-size:13px; font-weight:700; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.adt   { font-size:10px; color:var(--tll); font-weight:600; margin-top:2px; }
.adel  { background:none; border:none; cursor:pointer; opacity:.3; padding:2px; flex-shrink:0; display:flex; align-items:center; }

/* upload zone */
.upzone {
  margin:0 20px 12px;
  border:2px dashed color-mix(in srgb,var(--a1) 40%,transparent);
  border-radius:20px; padding:20px;
  display:flex; flex-direction:column; align-items:center; gap:8px;
  cursor:pointer; background:color-mix(in srgb,var(--a1) 5%,transparent);
}
.upzone:hover,.upzone.drag { border-color:var(--a1); background:color-mix(in srgb,var(--a1) 12%,transparent); }
.upzone-t { font-size:12px; font-weight:800; color:var(--tl); }
.upzone-s { font-size:10px; font-weight:600; color:var(--tll); }

/* ── NOTAS ── */
.ngrid { display:grid; grid-template-columns:1fr 1fr; gap:14px; padding:0 20px; }
.ngrid .wide { grid-column:1/-1; }
.ncard {
  border-radius:24px; padding:20px 18px 42px; cursor:pointer;
  transition:transform .2s; min-height:160px; position:relative; border:none;
}
.ncard:active { transform:scale(.96); }
.ntt  { font-size:16px; font-weight:800; margin-bottom:8px; line-height:1.3; color:#2d3748; }
.npv  { font-size:13px; font-weight:500; line-height:1.6; color:#4a5568; opacity:.85; }
.npv.checklist-preview { font-size:12px; line-height:1.8; }
.npv.checklist-preview .cl-item { display:flex; align-items:flex-start; gap:6px; }
.npv.checklist-preview .cl-bullet { flex-shrink:0; margin-top:2px; }
.ndt  { font-size:10px; font-weight:600; color:#718096; position:absolute; bottom:14px; left:18px; }
.ndel { position:absolute; top:12px; right:12px; background:none; border:none; cursor:pointer; opacity:.25; display:flex; align-items:center; }
.npin { position:absolute; top:12px; left:12px; font-size:14px; }

/* nota detalle checklist */
.note-checklist-body .cl-item { display:flex; align-items:flex-start; gap:9px; padding:6px 0; border-bottom:1px solid rgba(160,185,210,.12); font-size:13px; }
.note-checklist-body .cl-item:last-child { border-bottom:none; }
.note-checklist-body .cl-idx    { flex-shrink:0; font-size:11px; font-weight:800; color:var(--tll); min-width:18px; text-align:right; padding-top:1px; }
.note-checklist-body .cl-bullet { flex-shrink:0; font-size:14px; }
.note-checklist-body .cl-text   { flex:1; font-weight:600; line-height:1.5; }

/* editor de checklist */
.cl-editor { width:100%; border:1px solid rgba(160,185,210,.25); border-radius:14px; background:rgba(255,255,255,.75); overflow:hidden; }
.cl-editor-row { display:flex; align-items:center; gap:8px; padding:8px 12px; border-bottom:1px solid rgba(160,185,210,.1); }
.cl-editor-row:last-child { border-bottom:none; }
.cl-editor-num  { font-size:11px; font-weight:800; color:var(--tll); min-width:18px; text-align:right; flex-shrink:0; }
.cl-editor-bullet { flex-shrink:0; font-size:13px; }
.cl-editor-in   { flex:1; border:none; background:transparent; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:600; color:var(--tx); outline:none; padding:2px 0; }
.cl-editor-del  { background:none; border:none; cursor:pointer; opacity:.25; display:flex; align-items:center; flex-shrink:0; padding:2px; }
.cl-add-btn     { width:100%; padding:10px; border:none; background:transparent; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:12px; font-weight:700; color:var(--a1); display:flex; align-items:center; justify-content:center; gap:5px; border-top:1px dashed rgba(160,185,210,.2); }

/* ── items de factura (editor) ── */
.inv-item-row  { display:flex; gap:7px; align-items:center; padding:8px 0; border-bottom:1px solid rgba(160,185,210,.1); }
.inv-item-row:last-child { border-bottom:none; }
.inv-item-num  { font-size:10px; font-weight:800; color:var(--tll); min-width:16px; text-align:right; flex-shrink:0; }
.inv-item-in   { flex:1; border:1px solid rgba(160,185,210,.2); background:rgba(255,255,255,.7); border-radius:10px; padding:8px 10px; font-family:'DM Sans',sans-serif; font-size:12px; font-weight:600; color:var(--tx); outline:none; }
.inv-item-amt  { width:88px; flex-shrink:0; border:1px solid rgba(160,185,210,.2); background:rgba(255,255,255,.7); border-radius:10px; padding:8px 10px; font-family:'DM Sans',sans-serif; font-size:12px; font-weight:700; color:var(--tx); outline:none; text-align:right; }
.inv-item-del  { background:none; border:none; cursor:pointer; opacity:.25; display:flex; align-items:center; flex-shrink:0; }
.inv-items-wrap { border:1px solid rgba(160,185,210,.25); border-radius:14px; background:rgba(255,255,255,.75); overflow:hidden; margin-bottom:6px; }
.inv-add-btn   { width:100%; padding:9px; border:none; background:transparent; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:12px; font-weight:700; color:var(--a1); display:flex; align-items:center; justify-content:center; gap:5px; border-top:1px dashed rgba(160,185,210,.2); }
.inv-totals    { background:rgba(255,255,255,.6); border:1px solid rgba(160,185,210,.2); border-radius:12px; padding:10px 14px; margin-bottom:14px; }
.inv-total-row { display:flex; justify-content:space-between; align-items:center; padding:3px 0; }
.inv-total-lbl { font-size:11px; font-weight:700; color:var(--tl); }
.inv-total-val { font-size:12px; font-weight:800; color:var(--tx); }
.inv-total-row.grand { border-top:1.5px solid rgba(160,185,210,.3); margin-top:4px; padding-top:7px; }
.inv-total-row.grand .inv-total-lbl { font-size:13px; font-weight:800; color:var(--tx); }
.inv-total-row.grand .inv-total-val { font-size:15px; font-weight:900; color:var(--a1); }

/* ── PROYECTOS ── */
.proj-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; padding:0 20px; margin-bottom:8px; }
.proj-book {
  position:relative; border-radius:20px; overflow:hidden; cursor:pointer;
  min-height:155px; border:1px solid rgba(255,255,255,.9);
  box-shadow:0 6px 24px var(--sd); transition:transform .2s; background:var(--sf);
}
.proj-book:active { transform:scale(.97); }
.pb-spine  { position:absolute; left:0; top:0; bottom:0; width:10px; }
.pb-body   { padding:14px 12px 14px 20px; height:100%; display:flex; flex-direction:column; }
.pb-icon   { font-size:20px; margin-bottom:5px; }
.pb-name   { font-size:13px; font-weight:800; line-height:1.3; margin-bottom:3px; color:#2d3748; }
.pb-cat    { font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:.7px; opacity:.5; margin-bottom:8px; }
.pb-prog   { margin-top:auto; }
.pb-pct    { font-size:11px; font-weight:700; color:var(--tl); margin-bottom:3px; }
.pb-bar    { height:4px; border-radius:4px; background:rgba(0,0,0,.08); overflow:hidden; }
.pb-fill   { height:100%; border-radius:4px; }
.pb-steps  { font-size:9px; font-weight:600; color:var(--tll); margin-top:3px; }
.pb-del    { position:absolute; top:9px; right:9px; background:rgba(255,255,255,.8); border:none; cursor:pointer; width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; opacity:.5; font-size:11px; }

/* detalle proyecto */
.proj-detail {
  display:none; position:fixed; inset:0;
  background:var(--app-bg, linear-gradient(160deg,#e4f2ff,#ede8ff,#e4fff5));
  z-index:80; flex-direction:column; overflow:hidden;
}
.proj-detail.open { display:flex; animation:fu .25s ease; }
.pd-hdr {
  padding:12px 20px;
  padding-top:calc(12px + env(safe-area-inset-top));
  display:flex; align-items:center; gap:12px; flex-shrink:0;
  border-bottom:1px solid rgba(160,185,210,.15);
}
.pd-back {
  width:36px; height:36px; border-radius:50%; background:var(--bg); border:none;
  cursor:pointer; box-shadow:3px 3px 8px var(--sd),-2px -2px 6px var(--sl);
  display:flex; align-items:center; justify-content:center; font-size:18px; color:var(--tx); flex-shrink:0;
}
.pd-title { font-size:17px; font-weight:800; flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.pd-sp    { flex:1; overflow-y:scroll; -webkit-overflow-scrolling:touch; padding-bottom:calc(var(--nav-h) + 16px); }
.pd-sp::-webkit-scrollbar { display:none; }

/* timeline vertical */
.vtl      { padding:0 20px 20px; position:relative; }
.vtl-step { display:flex; gap:12px; position:relative; z-index:1; }
.vtl-left { display:flex; flex-direction:column; align-items:center; flex-shrink:0; width:34px; }
.vtl-dot  {
  width:34px; height:34px; border-radius:50%; border:3px solid var(--bg);
  display:flex; align-items:center; justify-content:center;
  font-size:12px; font-weight:800; flex-shrink:0; transition:all .3s; box-shadow:0 2px 8px rgba(0,0,0,.1);
}
.vtl-dot.d-done { background:var(--a3); color:#fff; }
.vtl-dot.d-next { background:var(--nav-active); color:#fff; animation:nextGlow 2s ease-in-out infinite; }
.vtl-dot.d-pend { background:var(--bg); color:var(--tll); }
@keyframes nextGlow {
  0%,100%{ box-shadow:0 0 0 0 rgba(58,143,201,.3); }
  50%    { box-shadow:0 0 0 6px rgba(58,143,201,.15); }
}
.vtl-line  { width:2px; flex:1; min-height:14px; margin-top:3px; }
.vtl-body  { flex:1; padding-bottom:18px; }
.vtl-card  { background:var(--sf); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,.88); border-radius:18px; box-shadow:0 3px 16px rgba(160,185,210,.16); overflow:hidden; }
.vtl-card.c-done { opacity:.7; }
.vtl-card-hdr  { padding:13px 14px; display:flex; align-items:flex-start; gap:10px; cursor:pointer; }
.vtl-info      { flex:1; min-width:0; }
.vtl-st        { font-size:13px; font-weight:800; }
.vtl-sd        { font-size:11px; color:var(--tl); margin-top:2px; line-height:1.4; }
.vtl-sm        { display:flex; gap:7px; align-items:center; margin-top:5px; flex-wrap:wrap; }
.vtl-tag       { font-size:9px; font-weight:800; padding:2px 8px; border-radius:9px; }
.vtl-chk       { width:26px; height:26px; border-radius:50%; border:2.5px solid; flex-shrink:0; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all .2s; }
.vtl-chk.ck-done { border-color:var(--a3); background:var(--a3); color:#fff; }
.vtl-chk.ck-next { border-color:var(--a1); }
.vtl-chk.ck-pend { border-color:rgba(160,185,210,.5); }
.vtl-exp       { display:none; padding:0 14px 14px; border-top:1px solid rgba(160,185,210,.1); }
.vtl-note      { background:rgba(255,255,255,.6); border-radius:12px; padding:10px 12px; font-size:12px; color:var(--tl); line-height:1.5; margin-bottom:10px; }
.sadj-row      { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:10px; }
.sadj-wrap     { position:relative; display:inline-flex; }
.sadj-thumb    { width:60px; height:60px; border-radius:10px; object-fit:cover; cursor:pointer; border:2px solid rgba(255,255,255,.8); }
.sadj-pdf      { width:60px; height:60px; border-radius:10px; background:rgba(220,60,60,.1); color:#c03030; display:flex; flex-direction:column; align-items:center; justify-content:center; font-size:8px; font-weight:700; cursor:pointer; gap:2px; border:2px solid rgba(255,255,255,.8); text-align:center; padding:4px; }
.sadj-del      { position:absolute; top:-5px; right:-5px; width:17px; height:17px; border-radius:50%; background:#fff; border:none; cursor:pointer; font-size:9px; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 5px rgba(0,0,0,.15); color:#c03030; }
.sadj-add      { width:60px; height:60px; border-radius:10px; border:2px dashed rgba(160,185,210,.5); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:3px; cursor:pointer; background:rgba(255,255,255,.4); }
.sadj-add-t    { font-size:8px; font-weight:700; color:var(--tll); }
.vtl-acts      { display:flex; gap:8px; margin-top:8px; }
.vact-btn      { flex:1; padding:8px; border-radius:11px; border:none; cursor:pointer; font-size:11px; font-weight:700; font-family:'DM Sans',sans-serif; display:flex; align-items:center; justify-content:center; gap:5px; }
.vact-del      { background:rgba(220,60,60,.1); color:#c03030; }
.vact-edit     { background:var(--c-blue-bg); color:var(--c-blue-tx); }

/* ── ARCHIVO ── */
.arch-grid   { display:grid; grid-template-columns:1fr 1fr; gap:14px; padding:0 20px; margin-bottom:8px; }
.arch-folder { position:relative; border-radius:20px; cursor:pointer; min-height:130px; overflow:hidden; border:1px solid rgba(255,255,255,.9); box-shadow:0 6px 24px var(--sd); transition:transform .2s; background:var(--sf); }
.arch-folder:active { transform:scale(.97); }
.af-top      { height:10px; }
.af-body     { padding:12px; }
.af-icon     { font-size:24px; margin-bottom:5px; }
.af-name     { font-size:13px; font-weight:800; color:#2d3748; margin-bottom:2px; line-height:1.3; }
.af-meta     { font-size:9px; font-weight:600; color:var(--tll); }
.af-del      { position:absolute; top:18px; right:9px; background:rgba(255,255,255,.8); border:none; cursor:pointer; width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; opacity:.5; font-size:11px; }
.arch-detail {
  display:none; position:fixed; inset:0;
  background:var(--app-bg, linear-gradient(160deg,#e4f2ff,#ede8ff,#e4fff5));
  z-index:80; flex-direction:column; overflow:hidden;
}
.arch-detail.open { display:flex; animation:fu .25s ease; }

/* cuadrícula de archivos */
.file-grid  { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; padding:0 20px; }
.file-item  { position:relative; border-radius:14px; overflow:hidden; aspect-ratio:1; cursor:pointer; background:rgba(255,255,255,.7); border:1px solid rgba(255,255,255,.88); box-shadow:0 3px 12px rgba(160,185,210,.15); }
.file-thumb { width:100%; height:100%; object-fit:cover; }
.file-ic    { width:100%; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4px; }
.file-ic-lbl { font-size:9px; font-weight:700; text-align:center; padding:0 4px; line-height:1.2; color:var(--tl); }
.file-overlay { position:absolute; bottom:0; left:0; right:0; padding:5px 6px; background:linear-gradient(transparent,rgba(0,0,0,.45)); }
.file-name  { font-size:8px; font-weight:700; color:#fff; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; display:block; }
.file-del   { position:absolute; top:5px; right:5px; width:20px; height:20px; border-radius:50%; background:rgba(255,255,255,.9); border:none; cursor:pointer; font-size:10px; display:flex; align-items:center; justify-content:center; color:#c03030; }

/* ── LIGHTBOX ── */
#lightbox {
  display:none; position:fixed; inset:0;
  background:rgba(10,20,40,.92); backdrop-filter:blur(14px);
  z-index:300; flex-direction:column;
}
#lightbox.open { display:flex; }
#lb-bar {
  width:100%; display:flex; align-items:center; justify-content:space-between;
  padding:14px 16px;
  padding-top:calc(14px + env(safe-area-inset-top));
  background:rgba(0,0,0,.4); flex-shrink:0; gap:8px;
}
#lb-title { font-size:12px; font-weight:800; color:#fff; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1; min-width:0; }
#lb-acts  { display:flex; gap:6px; flex-shrink:0; }
.lb-btn   { padding:8px 11px; border-radius:12px; border:none; cursor:pointer; font-size:11px; font-weight:800; font-family:'DM Sans',sans-serif; display:flex; align-items:center; gap:4px; white-space:nowrap; }
.lb-dl    { background:rgba(255,255,255,.18); color:#fff; }
.lb-print { background:var(--nav-active); color:#fff; }
.lb-close { background:rgba(255,255,255,.12); color:#fff; }
#lb-body  {
  flex:1; width:100%; display:flex; align-items:center; justify-content:center;
  overflow:hidden; padding:12px;
  padding-bottom:calc(12px + env(safe-area-inset-bottom));
}
#lb-img   { max-width:100%; max-height:100%; border-radius:14px; object-fit:contain; display:none; }
#lb-pdf   { width:100%; height:100%; border:none; border-radius:14px; display:none; background:#fff; }
#lb-nopreview { display:none; flex-direction:column; align-items:center; gap:14px; color:#fff; text-align:center; }

/* ── MODAL ── */
#mo {
  display:none; position:fixed; inset:0;
  background:rgba(60,80,100,.4); backdrop-filter:blur(8px);
  z-index:100; align-items:flex-end; justify-content:center;
}
#mo.open { display:flex; animation:oin .2s ease; }
@keyframes oin { from{opacity:0} to{opacity:1} }
#mb {
  background:var(--bg); border-radius:28px 28px 0 0;
  padding:0 0 calc(20px + env(safe-area-inset-bottom));
  width:100%; max-width:430px; max-height:85vh; overflow-y:auto;
  animation:mup .32s cubic-bezier(.34,1.56,.64,1);
}
#mb::-webkit-scrollbar { display:none; }
@keyframes mup { from{transform:translateY(100%)} to{transform:translateY(0)} }
.mhdr { display:flex; align-items:center; justify-content:space-between; padding:20px 22px 14px; border-bottom:1px solid rgba(160,185,210,.15); }
.mttl { font-size:17px; font-weight:800; }
.mcls { width:34px; height:34px; border-radius:50%; border:none; cursor:pointer; background:var(--bg); font-size:16px; display:flex; align-items:center; justify-content:center; }
.mbody { padding:16px 22px; }
/* campos del formulario */
.fg   { margin-bottom:14px; }
.fl2  { font-size:11px; font-weight:800; letter-spacing:.7px; text-transform:uppercase; color:var(--tll); margin-bottom:6px; display:block; }
.fi, .fsel, .fta {
  width:100%; padding:12px 14px;
  border:1px solid rgba(160,185,210,.25); border-radius:14px;
  font-family:'DM Sans',sans-serif; font-size:13px; font-weight:600;
  background:rgba(255,255,255,.75); color:var(--tx);
  box-shadow:inset 2px 2px 6px rgba(160,185,210,.18),inset -1px -1px 4px rgba(255,255,255,.8);
  outline:none;
}
.fi:focus,.fsel:focus,.fta:focus { border-color:var(--a1m); }
.fta  { resize:vertical; min-height:80px; }
.fsel { appearance:none; cursor:pointer; }
.fr   { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.bp   { width:100%; padding:14px; border-radius:16px; border:none; cursor:pointer; background:var(--nav-active); color:#fff; font-size:14px; font-weight:800; font-family:'DM Sans',sans-serif; display:flex; align-items:center; justify-content:center; gap:8px; }
.bd   { width:100%; padding:12px; border-radius:14px; border:none; cursor:pointer; background:rgba(220,60,60,.12); color:#c03030; font-size:13px; font-weight:700; margin-top:10px; font-family:'DM Sans',sans-serif; display:flex; align-items:center; justify-content:center; gap:8px; }

/* ── TOAST ── */
#toast {
  position:fixed; bottom:calc(var(--nav-h) + 14px); left:50%; transform:translateX(-50%) translateY(40px);
  width:88%; max-width:380px;
  background:rgba(255,255,255,.95); backdrop-filter:blur(18px);
  border:1px solid rgba(255,255,255,.95); border-radius:18px;
  padding:14px 16px; display:flex; gap:11px; align-items:center;
