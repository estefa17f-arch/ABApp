async function openFolderDetail(id) {
  var f = await GO('arch-folders', id); if (!f) return;
  CURR_FOLDER = f;
  document.getElementById('ad-title').textContent = f.name;
  document.getElementById('arch-detail').classList.add('open');
  await renderFolderFiles();
}
function closeArchDetail() {
  document.getElementById('arch-detail').classList.remove('open');
  CURR_FOLDER = null; renderArchive();
}

async function renderFolderFiles() {
  if (!CURR_FOLDER) return;
  var files = await GA('arch-files');
  var ff    = files.filter(function (x) { return x.folderId === CURR_FOLDER.id; })
                   .sort(function (a, b) { return b.created - a.created; });
  document.getElementById('ad-meta').textContent = ff.length + ' archivo' + (ff.length !== 1 ? 's' : '');
  var grid = document.getElementById('ad-files');
  if (!ff.length) {
    grid.innerHTML = '<div class="emp" style="grid-column:1/-1;"><div class="emp-t">Carpeta vacía</div><div class="emp-d">Sube archivos con ↑</div></div>';
    return;
  }
  var html = '';
  for (var i = 0; i < ff.length; i++) {
    var a      = ff[i];
    var isImg  = a.mime && a.mime.startsWith('image/');
    var isPdf  = a.mime === 'application/pdf';
    var aType  = isImg ? 'img' : isPdf ? 'pdf' : 'other';
    // FIX: prefijo '_arch_' para evitar colisiones con otras secciones
    var aKey   = '_arch_' + a.id;
    window[aKey] = { dataUrl: a.dataUrl, name: a.name || 'Archivo', type: aType };
    html += '<div class="file-item" onclick="openLBFromKey(\'' + aKey + '\')">';
    if (isImg)       html += '<img class="file-thumb" src="' + a.dataUrl + '" alt="' + esc(a.name) + '">';
    else if (isPdf)  html += '<div class="file-ic" style="background:rgba(220,60,60,.06);">' +
      '<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24" style="color:#c03030;"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6z"/></svg>' +
      '<span class="file-ic-lbl">PDF</span></div>';
    else             html += '<div class="file-ic" style="background:rgba(58,143,201,.06);">' +
      '<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24" style="color:var(--a1);"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6z"/></svg>' +
      '<span class="file-ic-lbl">' + esc((a.name || '').split('.').pop().toUpperCase()) + '</span></div>';
    html += '<div class="file-overlay"><span class="file-name">' + esc(a.name) + '</span></div>';
    html += '<button class="file-del" onclick="delArchFile(\'' + a.id + '\',event)">✕</button>';
    html += '</div>';
  }
  grid.innerHTML = html;
}

