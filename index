// ── TASKS ─────────────────────────────────────────────────
var KM = false, TF = 'all';
var PR = { high: { c: 'var(--a4)', l: 'Alta' }, medium: { c: 'var(--a5)', l: 'Media' }, low: { c: 'var(--a3)', l: 'Baja' } };

async function renderTasks() {
  var tasks = await GA('tasks');
  var done  = tasks.filter(function (t) { return t.status === 'done'; }).length;
  var total = tasks.length;
  var pct   = total > 0 ? Math.round(done / total * 100) : 0;

  var fl = document.getElementById('tc-fl');
  if (fl) {
    fl.style.strokeDashoffset = 158 * (1 - pct / 100);
    document.getElementById('tc-pct').textContent = pct + '%';
    document.getElementById('tc-sub').textContent = done + '/' + total;
  }

  var hi = tasks.filter(function (t) { return t.priority === 'high'; }).length;
  var mi = tasks.filter(function (t) { return t.priority === 'medium'; }).length;
  var li = tasks.filter(function (t) { return t.priority === 'low'; }).length;
  var pb = document.getElementById('t-prio-bk');
  if (pb) pb.innerHTML =
    '<div style="display:flex;gap:7px;align-items:center;"><div style="width:7px;height:7px;border-radius:50%;background:var(--a4);"></div><div style="font-size:10px;font-weight:700;">Alta: ' + hi + '</div></div>' +
    '<div style="display:flex;gap:7px;align-items:center;"><div style="width:7px;height:7px;border-radius:50%;background:var(--a5);"></div><div style="font-size:10px;font-weight:700;">Media: ' + mi + '</div></div>' +
    '<div style="display:flex;gap:7px;align-items:center;"><div style="width:7px;height:7px;border-radius:50%;background:var(--a3);"></div><div style="font-size:10px;font-weight:700;">Baja: ' + li + '</div></div>';

  var pend = tasks.filter(function (t) { return t.status !== 'done'; }).length;
  document.getElementById('t-sub').textContent = pend + ' pendiente' + (pend !== 1 ? 's' : '');

  if (KM) { renderKanban(tasks); return; }

  var fil = tasks;
  if      (TF === 'pending') fil = tasks.filter(function (t) { return t.status !== 'done'; });
  else if (TF === 'done')    fil = tasks.filter(function (t) { return t.status === 'done'; });
  else if (TF === 'high')    fil = tasks.filter(function (t) { return t.priority === 'high' && t.status !== 'done'; });

  var srt = fil.slice().sort(function (a, b) {
    var po = { high: 0, medium: 1, low: 2 };
    if (a.status === 'done' && b.status !== 'done') return 1;
    if (b.status === 'done' && a.status !== 'done') return -1;
    return (po[a.priority] || 1) - (po[b.priority] || 1);
  });

  var cnt = document.getElementById('t-items'); if (!cnt) return;
  if (!srt.length) { cnt.innerHTML = '<div class="emp"><div class="emp-t">Sin tareas</div><div class="emp-d">Agrega una tarea con +</div></div>'; return; }

  cnt.innerHTML = srt.map(function (t) {
    var pr    = PR[t.priority] || PR.medium;
    var isDone = t.status === 'done';
    var bw    = isDone ? 100 : (t.progress || 0);
    return '<div class="ti">' +
      '<div class="tck ' + (isDone ? 'done' : '') + '" style="border-color:' + pr.c + ';' + (isDone ? 'background:' + pr.c + ';' : '') + '" onclick="togTask(\'' + t.id + '\',event)">' + (isDone ? IC.check : '') + '</div>' +
      '<div class="tinf" onclick="openTDet(\'' + t.id + '\')">' +
        '<div class="tttl ' + (isDone ? 'done' : '') + '">' + esc(t.title) + '</div>' +
        '<div class="tmeta">' +
          '<span class="ttag" style="background:color-mix(in srgb,' + pr.c + ' 18%,transparent);color:' + pr.c + ';">' + pr.l + '</span>' +
