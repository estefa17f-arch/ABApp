  if (!dataUrl) { showToast('Archivo no disponible'); return; }
  LB_DATA = { dataUrl: dataUrl, name: name || 'Archivo', type: type };
  document.getElementById('lb-title').textContent = name || 'Documento';

  var img    = document.getElementById('lb-img');
  var pdf    = document.getElementById('lb-pdf');
  var no     = document.getElementById('lb-nopreview');
  var noName = document.getElementById('lb-nopreview-name');
  var extBtn = document.getElementById('lb-ext-btn');

  // FIX: ocultar todos los paneles antes de mostrar el correcto
  img.style.display = 'none';
  pdf.style.display = 'none';
  no.style.display  = 'none';
  if (extBtn) extBtn.style.display = 'none';

  if (type === 'img') {
    img.src = dataUrl;
    img.style.display = 'block';

  } else if (type === 'pdf') {
    try {
      var b64 = dataUrl.split(',')[1];
      var bin = atob(b64);
      var buf = new Uint8Array(bin.length);
      for (var i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
      var blob    = new Blob([buf], { type: 'application/pdf' });
      var blobUrl = URL.createObjectURL(blob);
      LB_DATA._blobUrl = blobUrl;

      if (isIOS) {
        // FIX iOS: iframe no funciona en iOS Safari — mostrar botón para abrir en nueva pestaña
        no.style.display = 'flex';
        if (noName) noName.textContent = name || '';
        if (extBtn) { extBtn.style.display = 'inline-flex'; extBtn.textContent = 'Abrir PDF ↗'; }
      } else {
        pdf.src = blobUrl;
        pdf.style.display = 'block';
        // FIX: fallback si el iframe falla (ej. Firefox bloquea blob en iframe)
        pdf.onerror = function () {
          pdf.style.display = 'none';
          no.style.display  = 'flex';
          if (noName) noName.textContent = name || '';
          if (extBtn) { extBtn.style.display = 'inline-flex'; extBtn.textContent = 'Abrir PDF ↗'; }
        };
      }
    } catch (e) {
      no.style.display = 'flex';
      if (noName) noName.textContent = name || '';
      if (extBtn) { extBtn.style.display = 'inline-flex'; extBtn.textContent = 'Abrir PDF ↗'; }
    }

  } else {
    no.style.display = 'flex';
    if (noName) noName.textContent = name || '';
    if (extBtn) { extBtn.style.display = 'inline-flex'; extBtn.textContent = 'Abrir archivo ↗'; }
  }

  document.getElementById('lightbox').classList.add('open');
}

// FIX: openLBFromKey busca la clave en window de forma segura
function openLBFromKey(key) {
  var d = window[key];
  if (!d) { showToast('Archivo no disponible'); return; }
  openLightboxDirect(d.dataUrl, d.name, d.type);
}

function lbOpenExternal() {
  if (!LB_DATA) return;
  if (LB_DATA._blobUrl) { window.open(LB_DATA._blobUrl, '_blank'); return; }
  try {
    var arr  = LB_DATA.dataUrl.split(',');
    var mime = arr[0].match(/:(.*?);/)[1];
    var bstr = atob(arr[1]); var n = bstr.length; var u8 = new Uint8Array(n);
    while (n--) u8[n] = bstr.charCodeAt(n);
    var blob = new Blob([u8], { type: mime });
    var url  = URL.createObjectURL(blob);
    window.open(url, '_blank');
    setTimeout(function () { URL.revokeObjectURL(url); }, 15000);
  } catch (e) { window.open(LB_DATA.dataUrl, '_blank'); }
}

function closeLB() {
  document.getElementById('lightbox').classList.remove('open');
  // FIX: limpiar src del iframe ANTES de revocar el blob para evitar errores de red
  var pdfEl = document.getElementById('lb-pdf');
  pdfEl.src = '';
  var imgEl = document.getElementById('lb-img');
  imgEl.src = '';
  if (LB_DATA && LB_DATA._blobUrl) {
    try { URL.revokeObjectURL(LB_DATA._blobUrl); } catch (e) {}
  }
  LB_DATA = null;
}

function lbDownload() {
  if (!LB_DATA) return;
  try {
    var url, a = document.createElement('a');
    if (LB_DATA._blobUrl) {
      url = LB_DATA._blobUrl;
    } else {
      var arr  = LB_DATA.dataUrl.split(',');
      var mime = arr[0].match(/:(.*?);/)[1];
      var bstr = atob(arr[1]); var n = bstr.length; var u8 = new Uint8Array(n);
      while (n--) u8[n] = bstr.charCodeAt(n);
      url = URL.createObjectURL(new Blob([u8], { type: mime }));
    }
    a.href = url; a.download = LB_DATA.name;
    document.body.appendChild(a); a.click();
    setTimeout(function () { a.remove(); if (!LB_DATA || !LB_DATA._blobUrl) URL.revokeObjectURL(url); }, 1000);
  } catch (e) {
    var a2 = document.createElement('a');
    a2.href = LB_DATA.dataUrl; a2.download = LB_DATA.name;
    document.body.appendChild(a2); a2.click();
    setTimeout(function () { a2.remove(); }, 500);
  }
}

function lbPrint() {
  if (!LB_DATA) return;
  if (LB_DATA.type === 'img') {
    var w = window.open('', '_blank');
    if (w) {
      w.document.write('<!DOCTYPE html><html><body style="margin:0;display:flex;align-items:center;justify-content:center;min-height:100vh;background:#000;">' +
        '<img src="' + LB_DATA.dataUrl + '" style="max-width:100%;max-height:100vh;" onload="window.print()"></body></html>');
      w.document.close();
    } else lbDownload();
  } else if (LB_DATA.type === 'pdf') {
    try {
      var blobUrl = LB_DATA._blobUrl;
      if (!blobUrl) {
        var arr  = LB_DATA.dataUrl.split(',');
        var bstr = atob(arr[1]); var n = bstr.length; var u8 = new Uint8Array(n);
        while (n--) u8[n] = bstr.charCodeAt(n);
        blobUrl = URL.createObjectURL(new Blob([u8], { type: 'application/pdf' }));
      }
      var w2 = window.open(blobUrl, '_blank');
      if (w2) setTimeout(function () { try { w2.print(); } catch (e) {} }, 1200);
      setTimeout(function () { URL.revokeObjectURL(blobUrl); }, 15000);
    } catch (e) { lbDownload(); }
  } else {
    showToast('Descarga el archivo para imprimir'); lbDownload();
  }
}

