    '<div style="font-size:10px;font-weight:600;color:var(--tll);margin-bottom:14px;">Tipo: ' + esc(file.type || 'desconocido') + ' · ' + formatBytes(file.size) + '</div>' +
    '<button class="bp" onclick="confirmFileNameSave()">💾 Subir archivo</button>' +
    '<button class="bd" onclick="closeM()">Cancelar</button>';
