<script type="module">
import { initializeApp }         from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, addDoc, setDoc, getDoc,
         getDocs, deleteDoc, doc, onSnapshot,
         serverTimestamp }        from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey:            "AIzaSyA4Zaiw8U5Ld8G4gCxCK4kEMfXmHgdFb_E",
  authDomain:        "abgroup-db7ea.firebaseapp.com",
  projectId:         "abgroup-db7ea",
  storageBucket:     "abgroup-db7ea.firebasestorage.app",
  messagingSenderId: "266741962255",
  appId:             "1:266741962255:web:0ebbb27c597bb8f4c9357a"
};

const fbApp = initializeApp(firebaseConfig);
const db    = getFirestore(fbApp);

/* ── helpers ── */
async function fbGetAll(col) {
  const snap = await getDocs(collection(db, col));
  return snap.docs.map(d => ({ id: d.id, ...d.data() }));
}
async function fbGet(col, id) {
  const snap = await getDoc(doc(db, col, String(id)));
  return snap.exists() ? { id: snap.id, ...snap.data() } : null;
}
async function fbAdd(col, data) {
  const ref = await addDoc(collection(db, col), { ...data, _ts: serverTimestamp() });
  return ref.id;
}
async function fbSet(col, id, data) {
  await setDoc(doc(db, col, String(id)), { ...data, _ts: serverTimestamp() });
  return id;
}
async function fbDel(col, id) {
  await deleteDoc(doc(db, col, String(id)));
}
function fbListen(col, cb) {
  return onSnapshot(collection(db, col), snap => {
    cb(snap.docs.map(d => ({ id: d.id, ...d.data() })));
  });
}

window.FB        = { fbGetAll, fbGet, fbAdd, fbSet, fbDel, fbListen, db };
window._fbReady  = true;
document.dispatchEvent(new Event('fb-ready'));
</script>

<style>
/* ═══════════════════════════════════════
   VARIABLES GLOBALES
   ═══════════════════════════════════════ */
:root {
  --a1:#3a8fc9; --a2:#8860c8; --a3:#4cc98a; --a4:#e8834a; --a5:#c8a820;
  --a1m:#5fa8d3; --a3m:#6dd9a8;
  --bg:#edf2f7; --sf:rgba(255,255,255,.75); --tx:#3d4a5c; --tl:#6b7a8d; --tll:#a0aec0;
  --sd:rgba(160,185,210,.45); --sl:rgba(255,255,255,.92);

