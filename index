async function saveAdj(file) {
  if (file.size > 10 * 1024 * 1024) { showToast('Máximo 10MB'); return; }
  var reader = new FileReader();
  reader.onload = async function (ev) {
    await GAD('attachments', { name: file.name, mime: file.type, size: file.size, dataUrl: ev.target.result, created: Date.now() });
    if (FT === 'adj') renderFinList();
    showToast('Archivo guardado ✓');
