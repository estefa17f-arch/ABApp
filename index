async function confirmFileNameSave() {
  var fname = (document.getElementById('f-fname') || {}).value.trim();
  var file  = _pendingFile; if (!file) return;
  if (!fname) fname = file.name;
  _pendingFile = null;
  closeM(); showToast('Subiendo…');
  var reader = new FileReader();
  reader.onload = async function (ev) {
    await GAD('arch-files', { folderId: CURR_FOLDER.id, name: fname, mime: file.type, size: file.size, dataUrl: ev.target.result, created: Date.now() });
    await renderFolderFiles(); showToast('"' + fname + '" subido ✓');
  };
  reader.readAsDataURL(file);
}
async function delArchFile(id, e) { e.stopPropagation(); await GD('arch-files', id); await renderFolderFiles(); showToast('Archivo eliminado'); }
async function delFolder(id, e) {
  e.stopPropagation();
  var files = await GA('arch-files'), ff = files.filter(function (x) { return x.folderId === id; });
  for (var i = 0; i < ff.length; i++) await GD('arch-files', ff[i].id);
  await GD('arch-folders', id); renderArchive(); showToast('Carpeta eliminada');
}

