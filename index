var PF = 'all', CURR_PROJ = null, CURR_STEP_ID = null;
var PCOLS = [
  { spine: 'var(--a1)', bg: 'linear-gradient(135deg,#e4f2ff,#ddeeff)' },
  { spine: 'var(--a2)', bg: 'linear-gradient(135deg,#ede8ff,#e2d8f8)' },
